/* ============ 全局样式 ============ */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background: #f5f7fa;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

view, text, image, input, button, scroll-view, navigator {
  box-sizing: border-box;
}

/* ============ 通用工具类 ============ */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

/* ============ 安全区域 ============ */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============ 页面容器 ============ */
.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

/* ============ 卡片样式 ============ */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* ============ 按钮样式 ============ */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ============ 文字颜色 ============ */
.text-primary { color: #667eea; }
.text-secondary { color: #999; }
.text-dark { color: #333; }
.text-light { color: #666; }

/* ============ 广告占位 ============ */
.ad-placeholder {
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  color: #bbb;
  font-size: 24rpx;
  margin: 24rpx;
}
