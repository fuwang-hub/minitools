/* ========================================
   万能工具箱 - 全局设计系统
   风格：白底清爽 + 蓝色强调
   ======================================== */

/* === 设计令牌 === */
/* 品牌色: #4F6EF6 (明亮蓝) */
/* 辅助色: #6C8AFF (浅蓝) */
/* 背景色: #F5F7FA (浅灰白) */
/* 卡片色: #FFFFFF */
/* 文字主: #1A1A1A */
/* 文字次: #666666 */
/* 文字弱: #999999 */
/* 分割线: #EAEEF3 */

/* === 基础重置 === */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1A1A1A;
  background: #F5F7FA;
  -webkit-font-smoothing: antialiased;
}

/* === 页面容器 === */

/* A类：标准工具页（灰底 + 顶部蓝色小Hero + 白色卡片）*/
.page-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* B类：沉浸式页面（天气等特殊页面）*/
.page-immersive {
  min-height: 100vh;
  padding-bottom: 40rpx;
  color: #fff;
}

/* === Hero 顶部区域（精简版，不再全屏） === */
.hero {
  background: linear-gradient(135deg, #4F6EF6, #6C8AFF);
  padding: 40rpx 30rpx 48rpx;
  text-align: center;
  color: #fff;
  border-radius: 0 0 32rpx 32rpx;
}

.hero-emoji {
  font-size: 64rpx;
  display: block;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.hero-desc {
  font-size: 24rpx;
  opacity: 0.85;
  display: block;
  margin-top: 4rpx;
}

/* === 白色卡片 === */
.card {
  margin: 20rpx 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
}

/* === 结果卡片 === */
.result-card {
  margin: 20rpx 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 高亮结果卡片（蓝色渐变背景）*/
.result-card-highlight {
  margin: 20rpx 30rpx;
  background: linear-gradient(135deg, #4F6EF6, #6C8AFF);
  border-radius: 20rpx;
  padding: 32rpx;
  color: #fff;
}

/* === 按钮系统 === */
.btn-primary {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4F6EF6, #6C8AFF);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 246, 0.3);
}

.btn-primary::after { border: none; }

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  height: 88rpx;
  line-height: 88rpx;
  background: #FFFFFF;
  color: #4F6EF6;
  border: 2rpx solid #4F6EF6;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-secondary::after { border: none; }

.btn-light {
  height: 80rpx;
  line-height: 80rpx;
  background: #F0F4FF;
  color: #4F6EF6;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

/* === 表单元素 === */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F7FA;
  border: 2rpx solid #EAEEF3;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.form-input:focus,
.form-input-focus {
  border-color: #4F6EF6;
  background: #fff;
}

/* === 标签/胶囊 === */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #F0F4FF;
  color: #4F6EF6;
}

.tag-active {
  background: #4F6EF6;
  color: #fff;
}

.tag-success {
  background: #E8F9EE;
  color: #34C759;
}

.tag-warning {
  background: #FFF4E6;
  color: #FF9500;
}

.tag-danger {
  background: #FFEBEE;
  color: #FF3B30;
}

/* === 分割线 === */
.divider {
  height: 1rpx;
  background: #EAEEF3;
  margin: 24rpx 0;
}

/* === 进度条 === */
.progress-bar {
  height: 8rpx;
  background: #EAEEF3;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F6EF6, #6C8AFF);
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* === 列表项 === */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EAEEF3;
}

.list-item:last-child {
  border-bottom: none;
}

/* === 空状态 === */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* === Section 标题 === */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  padding: 24rpx 30rpx 16rpx;
}

/* === 网格布局 === */
.grid-2 {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grid-2 > view {
  width: calc(50% - 8rpx);
}

.grid-3 {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grid-3 > view {
  width: calc(33.33% - 12rpx);
}

/* === 动画 === */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* === 广告位 === */
.ad-section {
  margin: 20rpx 30rpx;
}

/* === 底部安全区 === */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* === 辅助工具类 === */
.text-center { text-align: center; }
.text-blue { color: #4F6EF6; }
.text-gray { color: #999999; }
.text-bold { font-weight: 600; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

/* === SEO 隐藏文本（搜索引擎可见，用户不可见） === */
.seo-text {
  position: absolute;
  width: 1rpx;
  height: 1rpx;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  opacity: 0;
  pointer-events: none;
}
