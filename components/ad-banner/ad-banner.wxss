.ad-wrapper {
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.ad-dev-placeholder {
  background: linear-gradient(135deg, #f0f2f5 0%, #e8eaf0 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.ad-label {
  color: #aaa;
  font-size: 24rpx;
}
