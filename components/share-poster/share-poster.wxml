<!-- components/share-poster/share-poster.wxml -->
<view class="poster-mask" wx:if="{{show}}" catchtap="closePoster">
  <view class="poster-container" catchtap="">
    <!-- Canvas 画布 -->
    <canvas type="2d" id="posterCanvas" class="poster-canvas" style="width: 600px; height: 900px;"></canvas>
    <canvas canvas-id="posterCanvasLegacy" class="poster-canvas-legacy" style="width: 600px; height: 900px;"></canvas>

    <!-- 预览图 -->
    <view class="poster-preview" wx:if="{{posterReady}}">
      <image src="{{posterPath}}" class="poster-image" mode="widthFix"></image>
      <view class="poster-actions">
        <button class="btn-save" bindtap="savePoster">📥 保存到相册</button>
        <button class="btn-close" bindtap="closePoster">关闭</button>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="poster-loading" wx:if="{{!posterReady}}">
      <text class="loading-text">🎨 生成中...</text>
    </view>
  </view>
</view>
