/* components/share-poster/share-poster.wxss */
.poster-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.7); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.poster-container { position: relative; }
.poster-canvas { position: fixed; left: -9999px; top: -9999px; }
.poster-canvas-legacy { position: fixed; left: -9999px; top: -9999px; }
.poster-preview { display: flex; flex-direction: column; align-items: center; }
.poster-image { width: 560rpx; border-radius: 24rpx; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.3); }
.poster-actions { display: flex; gap: 20rpx; margin-top: 32rpx; }
.btn-save {
  padding: 20rpx 48rpx; background: #4F6EF6; color: #fff;
  border-radius: 44rpx; font-size: 28rpx; font-weight: 600; border: none;
}
.btn-close {
  padding: 20rpx 48rpx; background: rgba(255,255,255,0.2); color: #fff;
  border-radius: 44rpx; font-size: 28rpx; border: none;
}
.poster-loading { text-align: center; padding: 100rpx; }
.loading-text { color: #fff; font-size: 32rpx; }
