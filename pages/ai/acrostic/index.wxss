/* pages/ai/acrostic/index.wxss */
.form-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 36rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.form-hint { font-size: 28rpx; color: #6b7280; display: block; margin-bottom: 20rpx; }
.input-field { height: 88rpx; background: #f9fafb; border-radius: 16rpx; padding: 0 24rpx; font-size: 34rpx; border: 2rpx solid #e5e7eb; text-align: center; letter-spacing: 8rpx; }
.btn-gen { margin-top: 24rpx; height: 92rpx; line-height: 92rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 46rpx; font-size: 32rpx; }
.tip-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; }
.tip-title { font-size: 30rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 16rpx; }
.tip-item { font-size: 26rpx; color: #6b7280; display: block; margin-bottom: 8rpx; line-height: 1.6; }
.poem-card { margin: 20rpx 30rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); border-radius: 24rpx; padding: 48rpx 40rpx; border: 2rpx solid #fde68a; }
.poem-scroll { }
.poem-line { margin-bottom: 20rpx; font-size: 34rpx; color: #1f2937; line-height: 1.8; }
.first-char { color: #dc2626; font-weight: bold; font-size: 38rpx; }
.rest-chars { color: #374151; }
.actions { display: flex; gap: 16rpx; margin: 24rpx 30rpx; }
.btn-copy { flex: 1; height: 80rpx; line-height: 80rpx; background: #f3f4f6; color: #374151; border-radius: 40rpx; font-size: 28rpx; }
.btn-restart { flex: 1; height: 80rpx; line-height: 80rpx; background: #f3f4f6; color: #374151; border-radius: 40rpx; font-size: 28rpx; }
.btn-share { flex: 1; height: 80rpx; line-height: 80rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 40rpx; font-size: 28rpx; }
