<!--pages/ai/answer-book/index.wxml-->
<view class="container">
  <block wx:if="{{phase === 'input'}}">
    <view class="hero" style="background: linear-gradient(135deg, #1e1b4b, #312e81);">
      <text class="hero-emoji">📖</text>
      <text class="hero-title">答案之书</text>
      <text class="hero-desc">心中默想问题，翻开书页</text>
    </view>
    <view class="input-card">
      <text class="input-hint">在心中想一个问题...</text>
      <textarea class="input-area" placeholder="输入你的问题（选填）" value="{{question}}" bindinput="onInput" maxlength="100" />
      <button class="btn-ask" bindtap="askQuestion">✨ 翻开答案之书</button>
    </view>
    <view class="history-section" wx:if="{{history.length > 0}}">
      <text class="h-title">📝 历史记录</text>
      <view class="h-item" wx:for="{{history}}" wx:key="index">
        <text class="h-q">Q: {{item.q}}</text>
        <text class="h-a">A: {{item.a.emoji}} {{item.a.text}}</text>
      </view>
    </view>
  </block>

  <block wx:if="{{phase === 'thinking'}}">
    <view class="thinking-page">
      <text class="thinking-emoji">📖</text>
      <text class="thinking-text">正在翻阅答案之书...</text>
      <view class="thinking-dots">
        <text class="t-dot">•</text><text class="t-dot">•</text><text class="t-dot">•</text>
      </view>
    </view>
  </block>

  <block wx:if="{{phase === 'result' && answer}}">
    <view class="result-page" style="background: {{answer.type === 'positive' ? 'linear-gradient(135deg, #059669, #10b981)' : answer.type === 'neutral' ? 'linear-gradient(135deg, #d97706, #f59e0b)' : 'linear-gradient(135deg, #dc2626, #ef4444)'}};">
      <text class="result-emoji">{{answer.emoji}}</text>
      <text class="result-text">{{answer.text}}</text>
      <text class="result-hint">— 答案之书 —</text>
    </view>
    <view class="actions">
      <button class="btn-again" bindtap="askAgain">再问一次</button>
      <button class="btn-share" open-type="share">分享答案</button>
    </view>
  </block>
</view>
