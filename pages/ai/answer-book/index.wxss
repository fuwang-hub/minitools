/* pages/ai/answer-book/index.wxss */
.input-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 36rpx; }
.input-hint { font-size: 30rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 20rpx; }
.input-area { width: 100%; height: 160rpx; background: #f9fafb; border-radius: 16rpx; padding: 20rpx; font-size: 30rpx; border: 2rpx solid #e5e7eb; box-sizing: border-box; }
.btn-ask { margin-top: 24rpx; height: 96rpx; line-height: 96rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 48rpx; font-size: 34rpx; font-weight: 600; }
.thinking-page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); }
.thinking-emoji { font-size: 120rpx; }
.thinking-text { font-size: 32rpx; color: rgba(255,255,255,0.9); margin-top: 32rpx; }
.thinking-dots { margin-top: 16rpx; }
.t-dot { font-size: 48rpx; color: rgba(255,255,255,0.6); margin: 0 8rpx; }
.result-page { min-height: 70vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60rpx; }
.result-emoji { font-size: 120rpx; }
.result-text { font-size: 52rpx; font-weight: bold; color: #fff; margin-top: 32rpx; text-align: center; }
.result-hint { font-size: 26rpx; color: rgba(255,255,255,0.7); margin-top: 24rpx; }
.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; padding-bottom: 40rpx; }
.btn-again { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
.history-section { margin: 20rpx 30rpx; padding-bottom: 40rpx; }
.h-title { font-size: 30rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 16rpx; }
.h-item { background: #fff; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 8rpx; }
.h-q { font-size: 26rpx; color: #374151; display: block; }
.h-a { font-size: 26rpx; color: #6366F1; display: block; margin-top: 4rpx; }
