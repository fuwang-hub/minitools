/* pages/ai/daily-advice/index.wxss */

/* 日期头部 */
.date-header {
  padding: 32rpx 30rpx 24rpx;
  text-align: center;
}

.date-main {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.date-day {
  font-size: 72rpx;
  font-weight: 700;
  color: #4F6EF6;
  line-height: 1;
}

.date-right {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.date-ym {
  font-size: 24rpx;
  color: #999;
}

.date-week {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.date-lunar {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

/* 今日指数 */
.score-card {
  margin: 0 30rpx 20rpx;
  background: linear-gradient(135deg, #4F6EF6, #6C8AFF);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.score-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.score-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.score-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-info {
  flex: 1;
}

.score-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

.score-mood {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  margin-top: 6rpx;
}

.score-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 0.5s;
}

/* 宜忌卡片 */
.card {
  margin: 16rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 32rpx;
}

.card-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.yi-card {
  border-left: 8rpx solid #10B981;
}

.ji-card {
  border-left: 8rpx solid #EF4444;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.yi-tag {
  padding: 12rpx 28rpx;
  background: #ECFDF5;
  color: #059669;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.ji-tag {
  padding: 12rpx 28rpx;
  background: #FEF2F2;
  color: #DC2626;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 幸运三宫格 */
.lucky-grid {
  display: flex;
  gap: 12rpx;
  margin: 16rpx 30rpx;
}

.lucky-item {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.lucky-icon {
  font-size: 36rpx;
  display: block;
}

.lucky-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-top: 8rpx;
}

.lucky-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.color-item { border-top: 6rpx solid #F472B6; }
.num-item { border-top: 6rpx solid #FBBF24; }
.dir-item { border-top: 6rpx solid #60A5FA; }

/* 每日一言 */
.quote-card {
  margin: 16rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.quote-mark {
  font-size: 56rpx;
  color: #E5E7EB;
  font-family: Georgia, serif;
  line-height: 1;
  display: block;
}

.quote-mark.end {
  text-align: right;
  margin-top: -8rpx;
}

.quote-text {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
  display: block;
  padding: 0 16rpx;
}

/* 分享按钮 */
.share-btn {
  margin: 24rpx 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4F6EF6, #6C8AFF);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 246, 0.3);
}

.share-btn::after { border: none; }
.share-btn:active { opacity: 0.85; }
