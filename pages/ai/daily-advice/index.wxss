/* pages/ai/daily-advice/index.wxss */
.hero-lunar { font-size: 24rpx; opacity: 0.8; display: block; margin-top: 4rpx; }
.score-section { text-align: center; padding: 30rpx; }
.score-ring { width: 160rpx; height: 160rpx; border-radius: 50%; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); border: 8rpx solid #059669; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto; }
.score-num { font-size: 52rpx; font-weight: bold; color: #059669; line-height: 1; }
.score-label { font-size: 22rpx; color: #059669; }
.mood-text { font-size: 28rpx; color: #374151; margin-top: 16rpx; }
.yi-ji-card { margin: 0 30rpx; background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.yi-section, .ji-section { }
.divider { height: 1rpx; background: #f3f4f6; margin: 24rpx 0; }
.section-title { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 16rpx; }
.yi-title { color: #059669; }
.ji-title { color: #dc2626; }
.tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.yi-tag { font-size: 28rpx; padding: 10rpx 24rpx; background: #dcfce7; color: #059669; border-radius: 24rpx; }
.ji-tag { font-size: 28rpx; padding: 10rpx 24rpx; background: #fef2f2; color: #dc2626; border-radius: 24rpx; }
.lucky-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; }
.lucky-title { font-size: 30rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 16rpx; }
.lucky-row { display: flex; gap: 16rpx; }
.lucky-item { flex: 1; text-align: center; background: #fef9c3; border-radius: 16rpx; padding: 20rpx 12rpx; }
.l-label { font-size: 22rpx; color: #92400e; display: block; }
.l-value { font-size: 28rpx; font-weight: 600; color: #1f2937; display: block; margin-top: 6rpx; }
.quote-card { margin: 20rpx 30rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); border-radius: 24rpx; padding: 32rpx; text-align: center; }
.quote-icon { font-size: 40rpx; display: block; margin-bottom: 12rpx; }
.quote-text { font-size: 28rpx; color: #374151; line-height: 1.8; font-style: italic; }
.share-section { margin: 24rpx 30rpx; }
.btn-share { height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
