/* pages/test/love-language/index.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.hero { padding: 60rpx 40rpx; text-align: center; color: #fff; }
.hero-emoji { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.hero-title { font-size: 44rpx; font-weight: bold; display: block; }
.hero-desc { font-size: 26rpx; opacity: 0.9; display: block; margin-top: 8rpx; }
.progress-bar { margin: 30rpx 40rpx 10rpx; height: 8rpx; background: #e5e7eb; border-radius: 4rpx; }
.progress-fill { height: 100%; border-radius: 4rpx; transition: width 0.3s; }
.progress-text { display: block; text-align: center; font-size: 24rpx; color: #9ca3af; margin-bottom: 20rpx; }
.question-card { margin: 0 30rpx; background: #fff; border-radius: 24rpx; padding: 40rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.question-text { font-size: 34rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 30rpx; line-height: 1.6; }
.ab-options { display: flex; flex-direction: column; gap: 20rpx; }
.ab-option { display: flex; align-items: center; padding: 30rpx 24rpx; background: #fdf2f8; border-radius: 16rpx; border: 2rpx solid #fce7f3; }
.ab-option:active { background: #fce7f3; border-color: #EC4899; }
.ab-label { width: 48rpx; height: 48rpx; border-radius: 50%; background: #EC4899; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: bold; margin-right: 20rpx; flex-shrink: 0; line-height: 48rpx; text-align: center; }
.ab-text { font-size: 30rpx; color: #374151; line-height: 1.5; }
.result-hero { padding: 60rpx 40rpx; text-align: center; color: #fff; }
.result-emoji { font-size: 100rpx; display: block; margin-bottom: 16rpx; }
.result-name { font-size: 48rpx; font-weight: bold; display: block; }
.result-en { font-size: 26rpx; opacity: 0.8; display: block; margin-top: 8rpx; }
.result-card { margin: 20rpx 30rpx; background: #fff; border-radius: 20rpx; padding: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.card-title { font-size: 32rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 16rpx; }
.card-content { font-size: 28rpx; color: #4b5563; line-height: 1.8; display: block; }
.tips { margin-top: 8rpx; }
.tip-item { display: flex; align-items: flex-start; margin-bottom: 12rpx; }
.tip-dot { color: #EC4899; margin-right: 12rpx; font-size: 28rpx; }
.tip-text { font-size: 28rpx; color: #4b5563; line-height: 1.6; }
.bars { margin-top: 8rpx; }
.bar-item { display: flex; align-items: center; margin-bottom: 16rpx; }
.bar-label { font-size: 24rpx; color: #374151; width: 160rpx; flex-shrink: 0; }
.bar-track { flex: 1; height: 16rpx; background: #f3f4f6; border-radius: 8rpx; margin: 0 12rpx; }
.bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.5s; }
.bar-val { font-size: 24rpx; color: #6b7280; width: 70rpx; text-align: right; }
.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #EC4899, #F472B6); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
