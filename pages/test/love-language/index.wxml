<!--pages/test/love-language/index.wxml-->
<view class="page-container">
  <block wx:if="{{!showResult}}">
<view class="progress-bar"><view class="progress-fill" style="width: {{progress}}%; background: linear-gradient(90deg, #EC4899, #F472B6);"></view></view>
    <text class="progress-text">{{currentQuestion + 1}} / 10</text>
    <view class="question-card">
      <text class="question-text">{{questions[currentQuestion].text}}</text>
      <view class="ab-options">
        <view class="ab-option" bindtap="chooseOption" data-option="a">
          <text class="ab-label">A</text>
          <text class="ab-text">{{questions[currentQuestion].a}}</text>
        </view>
        <view class="ab-option" bindtap="chooseOption" data-option="b">
          <text class="ab-label">B</text>
          <text class="ab-text">{{questions[currentQuestion].b}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{showResult}}">
    <view class="result-hero">
      <text class="result-emoji">{{result.emoji}}</text>
      <text class="result-name">{{result.name}}</text>
      <text class="result-en">{{result.en}}</text>
    </view>
    <view class="result-card">
      <text class="card-title">💝 你的爱情语言</text>
      <text class="card-content">{{result.desc}}</text>
    </view>
    <view class="result-card">
      <text class="card-title">💑 最佳匹配</text>
      <text class="card-content">{{result.match}}</text>
    </view>
    <view class="result-card">
      <text class="card-title">💡 给伴侣的建议</text>
      <view class="tips">
        <view class="tip-item" wx:for="{{result.tips}}" wx:key="index">
          <text class="tip-dot">•</text>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>
    <view class="result-card">
      <text class="card-title">📊 五种语言占比</text>
      <view class="bars">
        <view class="bar-item" wx:for="{{allResults}}" wx:key="name">
          <text class="bar-label">{{item.emoji}} {{item.name}}</text>
          <view class="bar-track">
            <view class="bar-fill" style="width: {{item.percent}}%; background: {{item.color}};"></view>
          </view>
          <text class="bar-val">{{item.percent}}%</text>
        </view>
      </view>
    </view>
    <view class="actions">
      <button class="btn-restart" bindtap="restart">重新测试</button>
      <button class="btn-share" open-type="share">分享结果</button>
    </view>
  </block>

  <!-- SEO: 搜索引擎索引文本 -->
  <view class="seo-text" aria-hidden="true">五种爱情语言免费测试，了解你的爱情表达方式，肯定的言辞、服务的行动、真心的礼物、精心的时刻、身体的接触。</view>
</view>
