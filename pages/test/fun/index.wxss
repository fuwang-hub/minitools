/* pages/test/fun/index.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.hero { padding: 60rpx 40rpx; text-align: center; color: #fff; }
.hero-emoji { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.hero-title { font-size: 44rpx; font-weight: bold; display: block; }
.hero-desc { font-size: 26rpx; opacity: 0.9; display: block; margin-top: 8rpx; }
.test-list { margin: 20rpx 30rpx; }
.test-item { display: flex; align-items: center; background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.test-item:active { opacity: 0.8; }
.test-emoji { font-size: 60rpx; margin-right: 24rpx; }
.test-info { flex: 1; }
.test-name { font-size: 32rpx; font-weight: 600; color: #1f2937; display: block; }
.test-desc { font-size: 26rpx; color: #9ca3af; display: block; margin-top: 4rpx; }
.test-arrow { font-size: 40rpx; color: #d1d5db; }
.progress-bar { margin: 30rpx 40rpx 10rpx; height: 8rpx; background: #e5e7eb; border-radius: 4rpx; }
.progress-fill { height: 100%; border-radius: 4rpx; transition: width 0.3s; }
.progress-text { display: block; text-align: center; font-size: 24rpx; color: #9ca3af; margin-bottom: 20rpx; }
.question-card { margin: 0 30rpx; background: #fff; border-radius: 24rpx; padding: 40rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.question-text { font-size: 34rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 30rpx; line-height: 1.6; }
.options { display: flex; flex-direction: column; gap: 16rpx; }
.option { padding: 28rpx 24rpx; background: #f9fafb; border-radius: 16rpx; border: 2rpx solid #e5e7eb; text-align: center; }
.option:active { background: #fff7ed; border-color: #F97316; }
.option-text { font-size: 30rpx; color: #374151; }
.result-hero { padding: 60rpx 40rpx; text-align: center; color: #fff; }
.result-emoji { font-size: 100rpx; display: block; margin-bottom: 16rpx; }
.result-value { font-size: 48rpx; font-weight: bold; display: block; }
.result-card { margin: 20rpx 30rpx; background: #fff; border-radius: 20rpx; padding: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.card-title { font-size: 32rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 16rpx; }
.card-content { font-size: 28rpx; color: #4b5563; line-height: 1.8; display: block; }
.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #F97316, #FB923C); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
.back-link { text-align: center; margin-top: 20rpx; padding: 20rpx; }
.back-link text { font-size: 28rpx; color: #6b7280; }
