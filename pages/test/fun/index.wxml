<!--pages/test/fun/index.wxml-->
<view class="page-container">
  <!-- 测试列表 -->
  <block wx:if="{{mode === 'list'}}">
<view class="test-list">
      <view class="test-item" wx:for="{{tests}}" wx:key="id" bindtap="selectTest" data-id="{{item.id}}">
        <text class="test-emoji">{{item.emoji}}</text>
        <view class="test-info">
          <text class="test-name">{{item.name}}</text>
          <text class="test-desc">{{item.desc}}</text>
        </view>
        <text class="test-arrow">›</text>
      </view>
    </view>
  </block>

  <!-- 答题 -->
  <block wx:if="{{mode === 'test' && !showResult}}">
    <view class="progress-bar"><view class="progress-fill" style="width: {{progress}}%; background: {{currentTest.color}};"></view></view>
    <text class="progress-text">{{currentQuestion + 1}} / {{currentTest.questions.length}}</text>
    <view class="question-card">
      <text class="question-text">{{currentTest.questions[currentQuestion].text}}</text>
      <view class="options">
        <view class="option" wx:for="{{currentTest.questions[currentQuestion].options}}" wx:key="index" bindtap="handleAnswer" data-index="{{index}}">
          <text class="option-text">{{item}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 结果 -->
  <block wx:if="{{mode === 'test' && showResult}}">
    <view class="result-hero">
      <text class="result-emoji">{{result.emoji}}</text>
      <text class="result-value">{{result.value}}</text>
    </view>
    <view class="result-card">
      <text class="card-title">📝 结果分析</text>
      <text class="card-content">{{result.desc}}</text>
    </view>
    <view class="actions">
      <button class="btn-restart" bindtap="restart">重新测试</button>
      <button class="btn-share" open-type="share">分享结果</button>
    </view>
    <view class="back-link" bindtap="backToList">
      <text>← 返回测试列表</text>
    </view>
  </block>

  <!-- SEO: 搜索引擎索引文本 -->
  <view class="seo-text" aria-hidden="true">趣味心理测试合集，测测你的心理年龄、前世身份、隐藏超能力，轻松有趣。</view>
</view>
