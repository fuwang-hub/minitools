/* pages/test/enneagram/index.wxss */

.progress-bar { margin: 16rpx 30rpx 8rpx; height: 8rpx; background: #e5e7eb; border-radius: 4rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #6366F1, #8B5CF6); border-radius: 4rpx; transition: width 0.3s; }
.progress-text { display: block; text-align: center; font-size: 24rpx; color: #9ca3af; margin-bottom: 20rpx; }

.question-card { margin: 0 30rpx; background: #fff; border-radius: 24rpx; padding: 40rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.question-text { font-size: 34rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 30rpx; line-height: 1.6; }
.options { display: flex; flex-direction: column; gap: 20rpx; }
.option { display: flex; align-items: center; padding: 28rpx 24rpx; background: #f9fafb; border-radius: 16rpx; border: 2rpx solid #e5e7eb; }
.option:active { background: #eef2ff; border-color: #6366F1; }
.option-label { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; color: #6b7280; margin-right: 20rpx; flex-shrink: 0; line-height: 48rpx; text-align: center; }
.option-text { font-size: 30rpx; color: #374151; line-height: 1.5; }

.result-hero { padding: 60rpx 40rpx; text-align: center; color: #fff; }
.result-emoji { font-size: 100rpx; display: block; margin-bottom: 16rpx; }
.result-type { font-size: 30rpx; opacity: 0.9; display: block; }
.result-name { font-size: 48rpx; font-weight: bold; display: block; margin: 8rpx 0; }
.result-wing { font-size: 26rpx; opacity: 0.8; display: block; background: rgba(255,255,255,0.2); padding: 8rpx 24rpx; border-radius: 24rpx; display: inline-block; margin-top: 12rpx; }

.result-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.traits { display: flex; flex-wrap: wrap; gap: 12rpx; }
.trait-tag { font-size: 26rpx; padding: 8rpx 24rpx; border-radius: 24rpx; }

.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; }
