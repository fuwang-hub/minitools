/* pages/profile/index.wxss */
.profile-page { background: #f5f7fa; min-height: 100vh; padding-bottom: env(safe-area-inset-bottom); }

/* 用户信息区 */
.user-section { padding: 40rpx 30rpx 20rpx; }
.user-card, .login-card { display: flex; align-items: center; background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; flex-shrink: 0; background: #f0f0f0; }
.user-info { margin-left: 24rpx; flex: 1; }
.nickname { font-size: 34rpx; font-weight: 600; color: #1a1a1a; display: block; }
.user-desc { font-size: 24rpx; color: #999; display: block; margin-top: 6rpx; }

.login-avatar-placeholder { width: 100rpx; height: 100rpx; border-radius: 50%; background: #f0f4ff; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.login-icon { font-size: 48rpx; }
.login-info { margin-left: 24rpx; flex: 1; }
.login-title { font-size: 34rpx; font-weight: 600; color: #1a1a1a; display: block; }
.login-desc { font-size: 24rpx; color: #999; display: block; margin-top: 6rpx; }
.login-arrow { font-size: 40rpx; color: #ccc; }

/* 数据统计 */
.stats-row { display: flex; align-items: center; background: #fff; margin: 20rpx 30rpx; border-radius: 24rpx; padding: 30rpx 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #4F6EF6; display: block; }
.stat-label { font-size: 22rpx; color: #999; display: block; margin-top: 6rpx; }
.stat-divider { width: 1rpx; height: 48rpx; background: #eaeef3; }

/* 菜单列表 */
.menu-section { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.menu-item { display: flex; align-items: center; padding: 28rpx 30rpx; border-bottom: 1rpx solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; width: 48rpx; flex-shrink: 0; }
.menu-text { flex: 1; margin-left: 16rpx; }
.menu-title { font-size: 30rpx; color: #1a1a1a; display: block; }
.menu-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.menu-arrow { font-size: 32rpx; color: #ccc; flex-shrink: 0; }

/* 分享按钮特殊处理 */
.menu-share-btn { display: flex !important; align-items: center; width: 100%; background: transparent !important; border: none !important; padding: 0 !important; margin: 0 !important; text-align: left; line-height: normal !important; font-size: inherit; }
.menu-share-btn::after { display: none; }

/* 退出登录 */
.logout-section { margin: 40rpx 30rpx; }
.logout-btn { text-align: center; padding: 24rpx; background: #fff; border-radius: 24rpx; color: #ff3b30; font-size: 30rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }

/* 底部 */
.footer { text-align: center; padding: 40rpx 0; }
.footer-text { font-size: 22rpx; color: #ccc; }
