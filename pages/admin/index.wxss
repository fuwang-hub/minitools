/* pages/admin/index.wxss */
.metrics-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.metric-item { flex: 1; min-width: calc(33% - 12rpx); text-align: center; background: #f8fafc; border-radius: 16rpx; padding: 20rpx 8rpx; }
.metric-num { font-size: 36rpx; font-weight: 700; color: #4F6EF6; display: block; }
.metric-label { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

.retention-row { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.ret-item { flex: 1; text-align: center; background: #f8fafc; border-radius: 12rpx; padding: 16rpx 8rpx; }
.ret-item.ret-active { background: #eef2ff; }
.ret-day { font-size: 22rpx; color: #999; display: block; }
.ret-val { font-size: 26rpx; font-weight: 600; color: #1a1a1a; display: block; margin-top: 4rpx; }
.ret-val.ret-yes { color: #34C759; }

.rank-list { }
.rank-item { display: flex; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.rank-item:last-child { border-bottom: none; }
.rank-num { width: 48rpx; font-size: 26rpx; font-weight: 600; color: #4F6EF6; text-align: center; }
.rank-name { flex: 1; font-size: 26rpx; color: #374151; margin: 0 12rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.rank-bar-bg { width: 120rpx; height: 12rpx; background: #f3f4f6; border-radius: 6rpx; margin-right: 12rpx; }
.rank-bar-fill { height: 100%; background: linear-gradient(90deg, #4F6EF6, #6C8AFF); border-radius: 6rpx; }
.rank-count { width: 60rpx; text-align: right; font-size: 26rpx; font-weight: 600; color: #1a1a1a; }

.info-row { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #666; }
.info-val { font-size: 24rpx; color: #1a1a1a; max-width: 60%; text-align: right; word-break: break-all; }

.card-header { display: flex; justify-content: space-between; align-items: center; }
.toggle-arrow { font-size: 24rpx; color: #4F6EF6; }

.event-list { margin-top: 16rpx; max-height: 600rpx; overflow-y: auto; }
.event-item { display: flex; gap: 16rpx; padding: 10rpx 0; border-bottom: 1rpx solid #f9fafb; font-size: 22rpx; }
.event-time { color: #999; width: 260rpx; flex-shrink: 0; }
.event-name { color: #374151; font-weight: 500; }

.empty-text { text-align: center; padding: 32rpx; font-size: 26rpx; color: #999; }

.action-section { margin: 24rpx 30rpx 40rpx; display: flex; flex-wrap: wrap; gap: 16rpx; }
.btn-action { flex: 1; min-width: calc(50% - 8rpx); height: 80rpx; line-height: 80rpx; font-size: 26rpx; background: #f8fafc; color: #374151; border: 2rpx solid #e5e7eb; border-radius: 16rpx; }
.btn-action.btn-danger { background: #fef2f2; color: #dc2626; border-color: #fecaca; }

/* 排行通用 */
.rank-item { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #F0F2F5; gap: 12rpx; }
.rank-item:last-child { border-bottom: none; }
.rank-idx { font-size: 24rpx; color: #999; width: 36rpx; text-align: center; }
.rank-name { font-size: 26rpx; color: #333; flex: 1; }
.rank-val { font-size: 28rpx; color: #4F6EF6; font-weight: 600; }
.rank-sub { font-size: 22rpx; color: #999; width: 60rpx; text-align: right; }

/* 漏斗 */
.funnel-item { display: flex; align-items: center; padding: 14rpx 0; gap: 12rpx; border-bottom: 1rpx solid #F0F2F5; }
.funnel-item:last-child { border-bottom: none; }
.funnel-name { font-size: 26rpx; color: #333; width: 130rpx; }
.funnel-bar-bg { flex: 1; height: 16rpx; background: #EAEEF3; border-radius: 8rpx; overflow: hidden; }
.funnel-bar-fill { height: 100%; background: linear-gradient(90deg, #4F6EF6, #6C8AFF); border-radius: 8rpx; }
.funnel-rate { font-size: 28rpx; color: #4F6EF6; font-weight: 600; width: 70rpx; text-align: right; }
.funnel-detail { font-size: 22rpx; color: #999; width: 80rpx; text-align: right; }

/* 用户类型占比 */
.user-ratio { display: flex; gap: 16rpx; margin-top: 12rpx; }
.ratio-item { flex: 1; text-align: center; padding: 20rpx 12rpx; border-radius: 16rpx; }
.ratio-val { font-size: 40rpx; font-weight: 700; display: block; }
.ratio-label { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }
.new-user { background: #EEF2FF; }
.new-user .ratio-val { color: #4F6EF6; }
.returning-user { background: #FFF4E6; }
.returning-user .ratio-val { color: #F59E0B; }
.active-user { background: #ECFDF5; }
.active-user .ratio-val { color: #10B981; }

.export-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.export-box { width: 85%; background: #fff; border-radius: 24rpx; padding: 32rpx; max-height: 80vh; }
.export-title { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 16rpx; text-align: center; }
.export-textarea { width: 100%; height: 400rpx; font-size: 20rpx; font-family: monospace; background: #f8fafc; border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; }
