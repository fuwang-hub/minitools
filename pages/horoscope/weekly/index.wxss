/* pages/horoscope/weekly/index.wxss */
/* hero: 使用全局样式 */
.sign-grid { display: flex; flex-wrap: wrap; padding: 20rpx 20rpx; }
.sign-item { width: 25%; display: flex; flex-direction: column; align-items: center; padding: 24rpx 0; }
.sign-item:active { opacity: 0.7; }
.sign-emoji { font-size: 56rpx; }
.sign-name { font-size: 24rpx; color: #6b7280; margin-top: 8rpx; }
.sign-header { display: flex; justify-content: space-between; align-items: center; margin: 20rpx 30rpx 0; padding: 20rpx 24rpx; background: #fff; border-radius: 16rpx; }
.current-sign { font-size: 34rpx; font-weight: 600; color: #1f2937; }
.change-sign { font-size: 26rpx; color: #6366F1; }
.summary-card { margin: 16rpx 30rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); border-radius: 24rpx; padding: 32rpx; }
.overall-label { font-size: 28rpx; color: rgba(255,255,255,0.9); display: block; }
.overall-stars { font-size: 36rpx; display: block; margin: 8rpx 0; }
.summary-text { font-size: 28rpx; color: rgba(255,255,255,0.95); line-height: 1.8; display: block; margin-top: 12rpx; }
.lucky-info { display: flex; gap: 24rpx; margin-top: 16rpx; }
.lucky-item { font-size: 26rpx; color: #6366F1; background: rgba(99,102,241,0.1); padding: 8rpx 16rpx; border-radius: 12rpx; }
.fortune-card { margin: 16rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.fortune-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.fortune-icon { font-size: 36rpx; margin-right: 12rpx; }
.fortune-title { font-size: 30rpx; font-weight: 600; color: #1f2937; flex: 1; }
.fortune-stars { font-size: 28rpx; }
.fortune-desc { font-size: 28rpx; color: #4b5563; line-height: 1.8; display: block; }
