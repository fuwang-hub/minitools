<!--pages/horoscope/weekly/index.wxml-->
<view class="page-container">
  <view class="hero">
    <text class="hero-emoji">📅</text>
    <text class="hero-title">本周运势</text>
    <text class="hero-desc">{{weekRange}}</text>
  </view>

  <view class="sign-grid" wx:if="{{selectedSign < 0}}">
    <view class="sign-item" wx:for="{{signs}}" wx:key="index" bindtap="selectSign" data-index="{{item.index}}">
      <text class="sign-emoji">{{item.emoji}}</text>
      <text class="sign-name">{{item.name}}</text>
    </view>
  </view>

  <block wx:if="{{selectedSign >= 0 && result}}">
    <view class="sign-header" bindtap="selectSign" data-index="{{-1}}">
      <text class="current-sign">{{signs[selectedSign].emoji}} {{signs[selectedSign].name}}</text>
      <text class="change-sign">切换星座 ›</text>
    </view>

    <view class="summary-card">
      <text class="overall-label">本周综合运势</text>
      <text class="overall-stars">{{result.overallStars}}</text>
      <text class="summary-text">{{result.summary}}</text>
      <view class="lucky-info">
        <text class="lucky-item">🍀 幸运日：{{result.luckyDay}}</text>
        <text class="lucky-item">🔢 幸运数：{{result.luckyNums}}</text>
      </view>
    </view>

    <view class="fortune-card">
      <view class="fortune-header">
        <text class="fortune-icon">💕</text>
        <text class="fortune-title">爱情运势</text>
        <text class="fortune-stars">{{result.loveStars}}</text>
      </view>
      <text class="fortune-desc">{{result.loveDesc}}</text>
    </view>

    <view class="fortune-card">
      <view class="fortune-header">
        <text class="fortune-icon">💼</text>
        <text class="fortune-title">事业运势</text>
        <text class="fortune-stars">{{result.careerStars}}</text>
      </view>
      <text class="fortune-desc">{{result.careerDesc}}</text>
    </view>

    <view class="fortune-card">
      <view class="fortune-header">
        <text class="fortune-icon">💰</text>
        <text class="fortune-title">财运</text>
        <text class="fortune-stars">{{result.financeStars}}</text>
      </view>
      <text class="fortune-desc">{{result.financeDesc}}</text>
    </view>

    <view class="fortune-card">
      <view class="fortune-header">
        <text class="fortune-icon">❤️</text>
        <text class="fortune-title">健康运势</text>
        <text class="fortune-stars">{{result.healthStars}}</text>
      </view>
      <text class="fortune-desc">{{result.healthDesc}}</text>
    </view>
  </block>

  <ad wx:if="{{false}}" unit-id="adunit-xxx" ad-type="banner"></ad>
</view>
