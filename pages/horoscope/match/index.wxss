/* pages/horoscope/match/index.wxss */
.pair-display { display: flex; justify-content: center; align-items: center; padding: 40rpx 30rpx; gap: 30rpx; }
.pair-item { width: 180rpx; height: 180rpx; background: #fff; border-radius: 24rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 4rpx dashed #d1d5db; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.pair-item.selected { border: 4rpx solid #EC4899; }
.pair-emoji { font-size: 60rpx; }
.pair-name { font-size: 24rpx; color: #6b7280; margin-top: 8rpx; }
.pair-heart { font-size: 48rpx; }
.select-hint { text-align: center; margin-bottom: 20rpx; }
.select-hint text { font-size: 28rpx; color: #6b7280; }
.sign-grid { display: flex; flex-wrap: wrap; padding: 0 20rpx; }
.sign-item { width: 25%; display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }
.sign-item:active { opacity: 0.7; }
.sign-emoji { font-size: 48rpx; }
.sign-name { font-size: 22rpx; color: #6b7280; margin-top: 6rpx; }
.match-display { display: flex; justify-content: center; align-items: center; padding: 40rpx 30rpx; gap: 24rpx; }
.match-sign { display: flex; flex-direction: column; align-items: center; }
.match-emoji { font-size: 70rpx; }
.match-name { font-size: 28rpx; font-weight: 600; color: #1f2937; margin-top: 8rpx; }
.match-elem { font-size: 22rpx; margin-top: 4rpx; }
.match-score-circle { width: 140rpx; height: 140rpx; border-radius: 50%; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.score-num { font-size: 44rpx; font-weight: bold; color: #fff; line-height: 1; }
.score-pct { font-size: 22rpx; color: rgba(255,255,255,0.8); }
.result-card { margin: 16rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.dim-item { display: flex; align-items: center; margin-bottom: 16rpx; }
.dim-label { font-size: 26rpx; color: #374151; width: 100rpx; }
.dim-bar { flex: 1; height: 16rpx; background: #f3f4f6; border-radius: 8rpx; margin: 0 12rpx; }
.dim-fill { height: 100%; border-radius: 8rpx; transition: width 0.5s; }
.dim-val { font-size: 24rpx; color: #6b7280; width: 70rpx; text-align: right; }
.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
