/* pages/horoscope/chart/index.wxss */
.form-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 36rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.form-title { font-size: 34rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 24rpx; }
.form-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.form-label { font-size: 30rpx; color: #374151; }
.picker-val { font-size: 30rpx; color: #6366F1; }
.btn-generate { margin-top: 32rpx; height: 92rpx; line-height: 92rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 46rpx; font-size: 32rpx; font-weight: 500; }
.three-signs { display: flex; margin: 20rpx 30rpx; gap: 16rpx; }
.three-item { flex: 1; background: #fff; border-radius: 16rpx; padding: 24rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.three-label { font-size: 24rpx; color: #6b7280; display: block; }
.three-val { font-size: 30rpx; font-weight: 600; color: #1f2937; display: block; margin-top: 8rpx; }
.result-card { margin: 16rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.planet-list { margin-top: 8rpx; }
.planet-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f9fafb; }
.planet-emoji { font-size: 32rpx; margin-right: 12rpx; }
.planet-name { font-size: 28rpx; font-weight: 500; color: #1f2937; width: 80rpx; }
.planet-sign { font-size: 26rpx; color: #6366F1; width: 220rpx; }
.planet-meaning { font-size: 22rpx; color: #9ca3af; flex: 1; }
.elem-bars { margin-top: 12rpx; }
.elem-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.elem-label { font-size: 26rpx; width: 60rpx; }
.elem-bar { flex: 1; height: 16rpx; background: #f3f4f6; border-radius: 8rpx; margin: 0 12rpx; }
.elem-fill { height: 100%; border-radius: 8rpx; }
.elem-val { font-size: 24rpx; color: #6b7280; width: 30rpx; }
.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
