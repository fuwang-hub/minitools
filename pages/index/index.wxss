/* pages/index/index.wxss */

/* 签到栏 */
.checkin-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin: 16rpx 30rpx 0; padding: 20rpx 28rpx;
  background: #fff; border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.checkin-info { display: flex; align-items: center; gap: 16rpx; }
.checkin-streak { font-size: 24rpx; color: #F97316; font-weight: 600; }
.checkin-points { font-size: 24rpx; color: #6B7280; }
.checkin-btn {
  padding: 12rpx 32rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF);
  color: #fff; border-radius: 32rpx; font-size: 24rpx; font-weight: 600;
}
.checkin-btn.checked { background: #E5E7EB; color: #9CA3AF; }

/* 顶部蓝色区域 */
.header {
  background: linear-gradient(135deg, #4F6EF6, #6C8AFF);
  padding: 40rpx 30rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.app-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.app-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-top: 4rpx;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  margin-top: 24rpx;
}

.search-icon { font-size: 28rpx; margin-right: 12rpx; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  height: 72rpx;
}

.search-placeholder { color: #999; }

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 搜索结果 */
.search-results {
  margin: 16rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-result-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #EAEEF3;
}

.search-result-item:last-child { border-bottom: none; }
.search-result-item:active { background: #F5F7FA; }

.sr-emoji { font-size: 36rpx; margin-right: 16rpx; }
.sr-name { flex: 1; font-size: 28rpx; color: #1A1A1A; }
.sr-arrow { font-size: 32rpx; color: #ccc; }

.search-empty {
  padding: 48rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 模块区域 */
.modules {
  padding: 8rpx 0 20rpx;
}

.module-section {
  margin-bottom: 8rpx;
}

/* 模块标题 */
.module-header {
  padding: 24rpx 30rpx 8rpx;
}

.module-title-row {
  display: flex;
  align-items: center;
}

.module-emoji {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.module-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  flex: 1;
}

.module-count {
  font-size: 22rpx;
  color: #999;
  background: #F0F4FF;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.module-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  padding-left: 40rpx;
}

/* 工具网格 */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 12rpx 20rpx;
  gap: 0;
}

.tool-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.tool-item:active { opacity: 0.7; }

.tool-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.tool-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 10rpx;
  text-align: center;
  max-width: 140rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
