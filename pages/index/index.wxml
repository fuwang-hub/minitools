<view class="page-container">
  <!-- 顶部蓝色区域 -->
  <view class="header">
    <text class="app-title">🧰 万能工具箱</text>
    <text class="app-slogan">一个小程序，搞定日常所有小需求</text>
    <!-- 搜索框 -->
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索工具..." placeholder-class="search-placeholder"
             value="{{searchKeyword}}" bindinput="onSearchInput"
             bindfocus="onSearchFocus" bindblur="onSearchBlur"
             confirm-type="search" />
      <text class="search-clear" wx:if="{{searchKeyword}}" catchtap="onSearchClear">✕</text>
    </view>
  </view>

  <!-- 签到栏 -->
  <view class="checkin-bar" wx:if="{{!searchMode}}">
    <view class="checkin-info">
      <text class="checkin-streak" wx:if="{{streak > 0}}">🔥 连续{{streak}}天</text>
      <text class="checkin-points">⭐ {{points}}积分</text>
    </view>
    <view class="checkin-btn {{checkedIn ? 'checked' : ''}}" bindtap="doCheckin">
      <text>{{checkedIn ? '✅ 已签到' : '📅 签到'}}</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{searchMode && searchKeyword}}">
    <view class="search-result-item" wx:for="{{searchResults}}" wx:key="id"
          catchtap="onToolTap" data-path="{{item.path}}">
      <text class="sr-emoji">{{item.emoji}}</text>
      <text class="sr-name">{{item.name}}</text>
      <text class="sr-arrow">›</text>
    </view>
    <view class="search-empty" wx:if="{{searchResults.length === 0}}">
      <text>没有找到相关工具</text>
    </view>
  </view>

  <!-- 模块列表 -->
  <view class="modules" wx:if="{{!searchMode || !searchKeyword}}">
    <view class="module-section" wx:for="{{modules}}" wx:key="id">
      <!-- 模块标题栏 -->
      <view class="module-header" bindtap="onModuleTap" data-id="{{item.id}}">
        <view class="module-title-row">
          <text class="module-emoji">{{item.emoji}}</text>
          <text class="module-name">{{item.name}}</text>
          <text class="module-count">{{item.tools.length}}个</text>
        </view>
        <text class="module-desc">{{item.desc}}</text>
      </view>
      <!-- 工具网格（白色卡片） -->
      <view class="tool-grid">
        <view class="tool-item" wx:for="{{item.tools}}" wx:for-item="tool" wx:key="id"
              catchtap="onToolTap" data-path="{{tool.path}}">
          <view class="tool-icon-wrap">
            <text class="tool-emoji">{{tool.emoji}}</text>
          </view>
          <text class="tool-name">{{tool.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部广告 -->
  <ad-banner type="banner" />
</view>
