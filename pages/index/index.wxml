<view class="page-container">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="header-content">
      <text class="app-title">🧰 万能工具箱</text>
      <text class="app-slogan">一个小程序，搞定日常所有小需求</text>
    </view>

    <!-- 搜索框 -->
    <view class="search-bar" bindtap="onSearchTap">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索工具...</text>
    </view>
  </view>

  <!-- 模块列表 -->
  <view class="modules">
    <view class="module-card" wx:for="{{modules}}" wx:key="id"
          style="background: linear-gradient(135deg, {{item.color1}}, {{item.color2}});"
          bindtap="onModuleTap" data-id="{{item.id}}">
      <view class="module-header">
        <text class="module-emoji">{{item.emoji}}</text>
        <text class="module-name">{{item.name}}</text>
        <text class="module-count">{{item.tools.length}}个工具</text>
      </view>
      <view class="module-desc">
        <text>{{item.desc}}</text>
      </view>
      <!-- 工具网格 -->
      <view class="tool-grid">
        <view class="tool-item" wx:for="{{item.tools}}" wx:for-item="tool" wx:key="id"
              catchtap="onToolTap" data-path="{{tool.path}}">
          <text class="tool-emoji">{{tool.emoji}}</text>
          <text class="tool-name">{{tool.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部广告 -->
  <ad-banner type="banner" />
</view>
