<!--pages/metaphysics/divination/index.wxml-->
<view class="page-container">
<block wx:if="{{phase === 'ready'}}">
    <view class="altar">
      <text class="altar-emoji">🏮</text>
      <text class="altar-text">心中默念所求之事</text>
      <text class="altar-hint">然后点击下方开始求签</text>
      <button class="btn-shake" bindtap="startShake">🙏 开始求签</button>
    </view>
    <view class="history-section" wx:if="{{history.length > 0}}">
      <text class="history-title">📜 求签记录</text>
      <view class="history-item" wx:for="{{history}}" wx:key="index">
        <text class="h-num">第{{item.num}}签</text>
        <text class="h-type" style="color: {{item.typeColor}};">{{item.type}}</text>
        <text class="h-time">{{item.time}}</text>
      </view>
    </view>
  </block>

  <block wx:if="{{phase === 'shaking'}}">
    <view class="shaking">
      <text class="shake-emoji {{shakeCount % 2 === 0 ? 'shake-left' : 'shake-right'}}">🎋</text>
      <text class="shake-text">摇签中...</text>
      <view class="shake-dots">
        <text class="dot {{shakeCount >= 1 ? 'active' : ''}}">●</text>
        <text class="dot {{shakeCount >= 2 ? 'active' : ''}}">●</text>
        <text class="dot {{shakeCount >= 3 ? 'active' : ''}}">●</text>
        <text class="dot {{shakeCount >= 4 ? 'active' : ''}}">●</text>
        <text class="dot {{shakeCount >= 5 ? 'active' : ''}}">●</text>
        <text class="dot {{shakeCount >= 6 ? 'active' : ''}}">●</text>
      </view>
    </view>
  </block>

  <block wx:if="{{phase === 'result' && result}}">
    <view class="sign-card">
      <text class="sign-num">第 {{result.num}} 签</text>
      <text class="sign-type" style="color: {{result.typeColor}};">{{result.type}}</text>
      <view class="sign-poem">
        <text class="poem-text">{{result.poem}}</text>
      </view>
    </view>

    <view class="result-card">
      <text class="card-title">📖 签文解读</text>
      <text class="card-content">{{result.meaning}}</text>
    </view>

    <view class="result-card">
      <text class="card-title">💡 行动指引</text>
      <text class="card-content">{{result.advice}}</text>
    </view>

    <view class="disclaimer">
      <text>⚠️ 签文仅供参考，命运掌握在自己手中</text>
    </view>

    <view class="actions">
      <button class="btn-restart" bindtap="restart">再求一签</button>
      <button class="btn-share" open-type="share">分享签文</button>
    </view>
  </block>

  <!-- SEO: 搜索引擎索引文本 -->
  <view class="seo-text" aria-hidden="true">在线求签抽签工具，模拟观音灵签求签过程，虔诚摇签获取签文和解签建议。</view>
</view>
