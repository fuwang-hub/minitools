<!--pages/metaphysics/name/index.wxml-->
<view class="container">
  <view class="hero" style="background: linear-gradient(135deg, #f59e0b, #f97316);">
    <text class="hero-emoji">📝</text>
    <text class="hero-title">姓名测试</text>
    <text class="hero-desc">五格数理 · 姓名评分</text>
  </view>

  <block wx:if="{{!showResult}}">
    <view class="form-card">
      <view class="input-group">
        <text class="input-label">姓氏</text>
        <input class="input-field" placeholder="请输入姓氏" value="{{surname}}" bindinput="onSurnameInput" maxlength="2" />
      </view>
      <view class="input-group">
        <text class="input-label">名字</text>
        <input class="input-field" placeholder="请输入名字" value="{{givenName}}" bindinput="onGivenInput" maxlength="3" />
      </view>
      <button class="btn-analyze" bindtap="analyze">开始测试</button>
    </view>
  </block>

  <block wx:if="{{showResult && result}}">
    <view class="score-section">
      <view class="score-circle" style="border-color: {{result.totalScore >= 80 ? '#059669' : result.totalScore >= 60 ? '#F59E0B' : '#EF4444'}};">
        <text class="score-num">{{result.totalScore}}</text>
        <text class="score-label">分</text>
      </view>
      <text class="score-name">{{result.fullName}}</text>
      <text class="score-level">综合评级：{{result.level}}</text>
      <text class="score-wuxing">姓名五行：{{result.nameWuxing}}</text>
    </view>

    <view class="result-card">
      <text class="card-title">📊 五格分析</text>
      <view class="grid-list">
        <view class="grid-item" wx:for="{{result.gridItems}}" wx:key="name">
          <view class="grid-header">
            <text class="grid-name">{{item.name}}</text>
            <text class="grid-value">{{item.value}}</text>
            <text class="grid-luck" style="color: {{item.color}}; background: {{item.color}}15;">{{item.luck}}</text>
          </view>
          <text class="grid-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="result-card">
      <text class="card-title">🏷️ 性格特质</text>
      <view class="traits">
        <text class="trait-tag" wx:for="{{result.traits}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <view class="result-card">
      <text class="card-title">💼 事业提示</text>
      <text class="card-content">{{result.careerAdvice}}</text>
    </view>

    <view class="result-card">
      <text class="card-title">💕 感情提示</text>
      <text class="card-content">{{result.loveAdvice}}</text>
    </view>

    <view class="actions">
      <button class="btn-restart" bindtap="restart">重新测试</button>
      <button class="btn-share" open-type="share">分享结果</button>
    </view>
  </block>
</view>
