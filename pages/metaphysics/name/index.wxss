/* pages/metaphysics/name/index.wxss */
.form-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 36rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.input-group { margin-bottom: 24rpx; }
.input-label { font-size: 28rpx; color: #374151; display: block; margin-bottom: 12rpx; }
.input-field { height: 88rpx; background: #f9fafb; border-radius: 16rpx; padding: 0 24rpx; font-size: 32rpx; border: 2rpx solid #e5e7eb; }
.btn-analyze { margin-top: 16rpx; height: 92rpx; line-height: 92rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 46rpx; font-size: 32rpx; font-weight: 500; }
.score-section { text-align: center; padding: 40rpx 30rpx; }
.score-circle { width: 180rpx; height: 180rpx; border-radius: 50%; border: 8rpx solid; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto 20rpx; background: #fff; box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1); }
.score-num { font-size: 64rpx; font-weight: bold; color: #1f2937; line-height: 1; }
.score-label { font-size: 24rpx; color: #6b7280; }
.score-name { font-size: 40rpx; font-weight: 600; color: #1f2937; display: block; }
.score-level { font-size: 28rpx; color: #6b7280; display: block; margin-top: 8rpx; }
.score-wuxing { font-size: 26rpx; color: #f59e0b; display: inline-block; background: #fef3c7; padding: 6rpx 20rpx; border-radius: 16rpx; margin-top: 12rpx; }
.result-card { margin: 16rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.grid-list { margin-top: 8rpx; }
.grid-item { padding: 16rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.grid-header { display: flex; align-items: center; gap: 12rpx; }
.grid-name { font-size: 28rpx; font-weight: 500; color: #1f2937; }
.grid-value { font-size: 28rpx; color: #6366F1; font-weight: 600; }
.grid-luck { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.grid-desc { font-size: 24rpx; color: #9ca3af; margin-top: 4rpx; }
.traits { display: flex; flex-wrap: wrap; gap: 12rpx; }
.trait-tag { font-size: 26rpx; padding: 10rpx 24rpx; background: #fef3c7; color: #b45309; border-radius: 24rpx; }
.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
