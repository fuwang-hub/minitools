/* pages/metaphysics/dream/index.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.hero { padding: 60rpx 40rpx; text-align: center; color: #fff; }
.hero-emoji { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.hero-title { font-size: 44rpx; font-weight: bold; display: block; }
.hero-desc { font-size: 26rpx; opacity: 0.9; display: block; margin-top: 8rpx; }
.search-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.search-box { display: flex; gap: 12rpx; }
.search-input { flex: 1; height: 80rpx; background: #f9fafb; border-radius: 40rpx; padding: 0 28rpx; font-size: 30rpx; border: 2rpx solid #e5e7eb; }
.search-btn { width: 120rpx; height: 80rpx; line-height: 80rpx; text-align: center; background: linear-gradient(135deg, #4338ca, #6366F1); color: #fff; border-radius: 40rpx; font-size: 30rpx; }
.hot-section { margin: 20rpx 30rpx; }
.hot-title { font-size: 30rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 16rpx; }
.hot-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.hot-tag { font-size: 28rpx; padding: 12rpx 28rpx; background: #fff; color: #4338ca; border-radius: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.hot-tag:active { background: #eef2ff; }
.dream-header { text-align: center; padding: 40rpx 30rpx; }
.dream-emoji { font-size: 80rpx; display: block; }
.dream-title { font-size: 36rpx; font-weight: 600; color: #1f2937; display: block; margin: 12rpx 0; }
.dream-luck { font-size: 28rpx; padding: 8rpx 28rpx; border-radius: 20rpx; display: inline-block; }
.result-card { margin: 16rpx 30rpx; background: #fff; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.card-title { font-size: 32rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 16rpx; }
.card-content { font-size: 28rpx; color: #4b5563; line-height: 1.8; display: block; }
.disclaimer { text-align: center; margin: 20rpx 30rpx; }
.disclaimer text { font-size: 24rpx; color: #9ca3af; }
.actions { display: flex; gap: 20rpx; margin: 20rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4338ca, #6366F1); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
