/* pages/metaphysics/bazi/index.wxss */
.form-card { margin: 20rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 36rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.form-title { font-size: 34rpx; font-weight: 600; color: #1f2937; display: block; margin-bottom: 24rpx; }
.form-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.form-label { font-size: 30rpx; color: #374151; }
.picker-val { font-size: 30rpx; color: #b45309; }
.btn-analyze { margin-top: 32rpx; height: 92rpx; line-height: 92rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 46rpx; font-size: 32rpx; }
.bazi-card { margin: 20rpx 30rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); border-radius: 24rpx; padding: 32rpx; }
.bazi-title { font-size: 32rpx; font-weight: 600; color: #92400e; display: block; text-align: center; margin-bottom: 20rpx; }
.bazi-grid { display: flex; gap: 12rpx; }
.bazi-col { flex: 1; text-align: center; background: rgba(255,255,255,0.7); border-radius: 12rpx; padding: 16rpx 8rpx; }
.bazi-label { font-size: 22rpx; color: #92400e; display: block; }
.bazi-gan { display: none; }
.bazi-text { font-size: 36rpx; font-weight: bold; color: #1f2937; display: block; margin: 8rpx 0; }
.bazi-wuxing { font-size: 22rpx; color: #b45309; display: block; }
.shengxiao { font-size: 26rpx; color: #92400e; display: block; text-align: center; margin-top: 16rpx; }
.result-card { margin: 16rpx 30rpx; background: #fff; border-radius: 24rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.wuxing-bars { margin-top: 8rpx; }
.wx-row { display: flex; align-items: center; margin-bottom: 14rpx; }
.wx-label { font-size: 30rpx; width: 50rpx; font-weight: 600; }
.wx-bar { flex: 1; height: 20rpx; background: #f3f4f6; border-radius: 10rpx; margin: 0 12rpx; }
.wx-fill { height: 100%; border-radius: 10rpx; }
.wx-val { font-size: 26rpx; color: #6b7280; width: 30rpx; }
.wx-note { font-size: 26rpx; color: #EF4444; display: block; margin-top: 12rpx; }
.actions { display: flex; gap: 20rpx; margin: 30rpx 30rpx; }
.btn-restart { flex: 1; height: 88rpx; line-height: 88rpx; background: #f3f4f6; color: #374151; border-radius: 44rpx; font-size: 30rpx; }
.btn-share { flex: 1; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 30rpx; }
