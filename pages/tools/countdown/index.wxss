/* pages/tools/countdown/index.wxss */
.page-immersive { min-height: 100vh; padding-bottom: 40rpx; }
.header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 30rpx; }
.h-title { font-size: 34rpx; color: #fff; font-weight: 700; }
.add-btn { padding: 12rpx 30rpx; background: rgba(255,255,255,0.25); border-radius: 24rpx; font-size: 26rpx; color: #fff; }
.event-card { margin: 12rpx 30rpx; background: rgba(255,255,255,0.95); border-radius: 24rpx; padding: 24rpx; display: flex; justify-content: space-between; align-items: center; }
.event-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.event-emoji { font-size: 40rpx; }
.event-name { font-size: 28rpx; color: #1f2937; font-weight: 600; display: block; }
.event-date { font-size: 22rpx; color: #9ca3af; display: block; margin-top: 4rpx; }
.event-right { text-align: right; }
.event-days { font-size: 52rpx; font-weight: 700; display: block; line-height: 1; }
.event-label { font-size: 22rpx; color: #6b7280; display: block; }
.event-today { font-size: 32rpx; font-weight: 600; color: #f59e0b; }
.empty { text-align: center; padding: 80rpx 0; }
.empty-icon { font-size: 64rpx; display: block; }
.empty-text { font-size: 30rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 16rpx; }
.empty-hint { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 8rpx; }
.tips { text-align: center; padding: 16rpx; }
.tips-text { font-size: 22rpx; color: rgba(255,255,255,0.5); }
/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal { width: 85%; background: #fff; border-radius: 24rpx; padding: 36rpx; }
.modal-title { font-size: 32rpx; font-weight: 600; color: #1f2937; display: block; text-align: center; margin-bottom: 24rpx; }
.m-row { margin-bottom: 24rpx; }
.m-label { font-size: 26rpx; color: #6b7280; display: block; margin-bottom: 12rpx; }
.m-input { border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; color: #1f2937; }
.m-picker { font-size: 28rpx; color: #1f2937; border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 16rpx; display: block; }
.type-btns { display: flex; gap: 12rpx; }
.t-btn { flex: 1; text-align: center; padding: 16rpx; border: 2rpx solid #e5e7eb; border-radius: 12rpx; font-size: 26rpx; color: #6b7280; }
.t-btn.active { border-color: #ec4899; color: #ec4899; background: #fdf2f8; }
.emoji-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.emoji-opt { font-size: 32rpx; padding: 8rpx; border-radius: 8rpx; }
.emoji-opt.active { background: #fdf2f8; border: 2rpx solid #ec4899; }
.modal-btns { display: flex; gap: 16rpx; margin-top: 24rpx; }
.m-cancel { flex: 1; text-align: center; padding: 20rpx; border: 2rpx solid #e5e7eb; border-radius: 12rpx; font-size: 28rpx; color: #6b7280; }
.m-save { flex: 1; text-align: center; padding: 20rpx; background: #ec4899; color: #fff; border-radius: 12rpx; font-size: 28rpx; font-weight: 600; }
