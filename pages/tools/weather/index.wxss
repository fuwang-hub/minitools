/* pages/tools/weather/index.wxss */
.page-immersive { min-height: 100vh; padding-bottom: 40rpx; color: #fff; }

/* 配置提示 */
.config-tip { margin: 40rpx; background: rgba(255,255,255,0.15); border-radius: 24rpx; padding: 48rpx 36rpx; text-align: center; backdrop-filter: blur(10px); }
.tip-emoji { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.tip-title { font-size: 34rpx; font-weight: bold; display: block; margin-bottom: 24rpx; }
.tip-step { font-size: 26rpx; display: block; text-align: left; line-height: 2; opacity: 0.9; }
.tip-note { font-size: 24rpx; display: block; margin-top: 20rpx; opacity: 0.7; background: rgba(255,255,255,0.1); padding: 12rpx 24rpx; border-radius: 20rpx; }

/* 加载 */
.loading-mask { text-align: center; padding-top: 200rpx; }
.loading-icon { font-size: 80rpx; display: block; animation: pulse 1.5s ease-in-out infinite; }
.loading-text { font-size: 28rpx; opacity: 0.8; display: block; margin-top: 16rpx; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

/* 错误提示 */
.error-tip { margin: 60rpx 40rpx; text-align: center; }
.error-icon { font-size: 60rpx; display: block; }
.error-text { font-size: 28rpx; display: block; margin: 16rpx 0; opacity: 0.8; }
.retry-btn { display: inline-block; padding: 16rpx 48rpx; background: rgba(255,255,255,0.2); border-radius: 32rpx; font-size: 28rpx; margin-top: 16rpx; }

/* 顶部 */
.top-bar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 36rpx; }
.city-btn { display: flex; align-items: center; }
.city-name { font-size: 32rpx; font-weight: 600; }
.city-arrow { font-size: 24rpx; margin-left: 8rpx; opacity: 0.7; }
.update-time { font-size: 22rpx; opacity: 0.6; }

/* 核心天气 */
.main-weather { text-align: center; padding: 20rpx 36rpx 40rpx; }
.temp-big { font-size: 180rpx; font-weight: 200; line-height: 1; display: block; }
.weather-meta { margin-top: 8rpx; }
.weather-text { font-size: 34rpx; }
.feels-like { font-size: 26rpx; opacity: 0.7; margin-left: 16rpx; }
.weather-detail-row { display: flex; justify-content: center; align-items: center; gap: 20rpx; margin-top: 16rpx; flex-wrap: wrap; }
.detail-item { font-size: 24rpx; opacity: 0.8; }
.aqi-tag { padding: 6rpx 16rpx; border-radius: 16rpx; font-size: 22rpx; }

/* 通用卡片 */
.card { margin: 16rpx 30rpx; background: rgba(255,255,255,0.12); border-radius: 24rpx; padding: 28rpx; backdrop-filter: blur(10px); }
.card-title { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 20rpx; }

/* 逐小时 */
.hourly-scroll { width: 100%; white-space: nowrap; }
.hourly-list { display: inline-flex; gap: 8rpx; }
.hourly-item { display: inline-flex; flex-direction: column; align-items: center; width: 100rpx; flex-shrink: 0; }
.h-time { font-size: 22rpx; opacity: 0.7; }
.h-icon { font-size: 36rpx; margin: 8rpx 0; }
.h-temp { font-size: 26rpx; font-weight: 500; }

/* 多日预报 */
.daily-list { }
.daily-row { display: flex; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.daily-row:last-child { border-bottom: none; }
.d-day { width: 80rpx; font-size: 26rpx; flex-shrink: 0; }
.d-icon { width: 50rpx; font-size: 32rpx; text-align: center; flex-shrink: 0; }
.d-text { width: 90rpx; font-size: 24rpx; opacity: 0.8; flex-shrink: 0; }
.d-temp-bar { flex: 1; display: flex; align-items: center; gap: 10rpx; }
.d-lo { font-size: 24rpx; opacity: 0.6; width: 60rpx; text-align: right; }
.d-hi { font-size: 24rpx; font-weight: 500; width: 60rpx; }
.d-bar-bg { flex: 1; height: 8rpx; background: rgba(255,255,255,0.15); border-radius: 4rpx; position: relative; }
.d-bar-fill { position: absolute; top: 0; height: 100%; border-radius: 4rpx; background: linear-gradient(90deg, #60a5fa, #f97316); }

/* 日出日落 */
.sun-card { }
.sun-row { display: flex; align-items: center; justify-content: space-around; padding: 16rpx 0; }
.sun-item { display: flex; flex-direction: column; align-items: center; }
.sun-icon { font-size: 40rpx; }
.sun-label { font-size: 22rpx; opacity: 0.6; margin-top: 6rpx; }
.sun-time { font-size: 28rpx; font-weight: 500; margin-top: 4rpx; }
.sun-arc { font-size: 24rpx; opacity: 0.4; }

/* 生活指数 */
.indices-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.index-item { width: calc(33.33% - 12rpx); background: rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx 12rpx; text-align: center; box-sizing: border-box; }
.idx-emoji { font-size: 36rpx; display: block; }
.idx-name { font-size: 22rpx; opacity: 0.7; display: block; margin-top: 6rpx; }
.idx-value { font-size: 26rpx; font-weight: 500; display: block; margin-top: 4rpx; }

/* 底部 */
.footer { text-align: center; padding: 32rpx; }
.footer-text { font-size: 22rpx; opacity: 0.4; display: block; }
.share-btn { margin-top: 16rpx; background: rgba(255,255,255,0.15) !important; color: #fff !important; border: none !important; font-size: 24rpx !important; border-radius: 24rpx !important; }

/* 城市选择器 */
.city-picker-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 100; }
.city-picker { position: fixed; bottom: 0; left: 0; width: 100%; height: 70vh; background: #1a1a2e; border-radius: 32rpx 32rpx 0 0; z-index: 101; display: flex; flex-direction: column; box-sizing: border-box; }
.picker-header { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 36rpx; border-bottom: 1rpx solid rgba(255,255,255,0.1); }
.picker-title { font-size: 32rpx; font-weight: 600; }
.picker-close { font-size: 36rpx; opacity: 0.6; padding: 8rpx; }
.search-bar { padding: 16rpx 36rpx; }
.search-input { background: rgba(255,255,255,0.1); border-radius: 16rpx; padding: 16rpx 24rpx; font-size: 28rpx; color: #fff; }
.relocate-btn { padding: 16rpx 36rpx; font-size: 28rpx; opacity: 0.8; }
.city-list { flex: 1; padding: 0 36rpx; }
.city-item { padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); font-size: 30rpx; }
.no-result { text-align: center; padding: 40rpx; opacity: 0.5; font-size: 28rpx; }
