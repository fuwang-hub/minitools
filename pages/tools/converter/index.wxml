<view class="page-container">
<!-- 分类 Tab -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === index ? 'active' : ''}}"
          wx:for="{{categories}}" wx:key="key"
          bindtap="onTabChange" data-index="{{index}}">
      <text>{{item.name}}</text>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="card convert-card">
    <!-- From -->
    <view class="unit-row">
      <picker class="unit-picker" range="{{currentUnits}}" range-key="name"
              value="{{fromIndex}}" bindchange="onFromChange">
        <view class="picker-text">{{currentUnits[fromIndex].name}} ▾</view>
      </picker>
      <input class="unit-input" type="digit" value="{{fromValue}}"
             bindinput="onInputChange" placeholder="输入数值" />
    </view>

    <!-- 交换按钮 -->
    <view class="swap-btn" bindtap="onSwap">
      <text>🔄</text>
    </view>

    <!-- To -->
    <view class="unit-row">
      <picker class="unit-picker" range="{{currentUnits}}" range-key="name"
              value="{{toIndex}}" bindchange="onToChange">
        <view class="picker-text">{{currentUnits[toIndex].name}} ▾</view>
      </picker>
      <view class="unit-result">
        <text class="result-value">{{toValue}}</text>
      </view>
    </view>
  </view>

  <ad-banner type="banner" />

  <!-- SEO: 搜索引擎索引文本 -->
  <view class="seo-text" aria-hidden="true">万能单位换算工具，支持长度、重量、温度、面积、体积、速度六大类单位在线换算。</view>
</view>
