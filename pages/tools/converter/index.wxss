.hero {
  padding: 40rpx 32rpx;
  text-align: center;
}
.hero-emoji { font-size: 56rpx; display: block; margin-bottom: 8rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }

/* Tab */
.tab-bar {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}
.tab-item {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #fff;
  color: #666;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.tab-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

/* 换算卡片 */
.convert-card { margin-top: 12rpx; }

.unit-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.unit-picker {
  width: 200rpx;
  margin-right: 20rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  padding: 12rpx 16rpx;
  background: #f5f7ff;
  border-radius: 12rpx;
}

.unit-input {
  flex: 1;
  text-align: right;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.unit-result {
  flex: 1;
  text-align: right;
}

.result-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.swap-btn {
  text-align: center;
  padding: 16rpx;
  font-size: 36rpx;
}
.swap-btn:active { opacity: 0.5; }
