.hero { padding: 40rpx 32rpx; text-align: center; }
.hero-emoji { font-size: 56rpx; display: block; margin-bottom: 8rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }

.tab-bar { display: flex; padding: 16rpx 24rpx; gap: 12rpx; }
.tab-item {
  flex: 1; text-align: center; padding: 16rpx; border-radius: 24rpx;
  font-size: 26rpx; background: #fff; color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.tab-item.active { background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; }

.date-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.date-label { font-size: 28rpx; color: #666; }
.date-picker {
  font-size: 28rpx; color: #4F6EF6; font-weight: 500;
  padding: 12rpx 20rpx; background: #f5f7ff; border-radius: 12rpx;
}
.days-input {
  width: 240rpx; text-align: right; font-size: 30rpx; font-weight: 500; color: #333;
}

.result-box {
  text-align: center; padding: 32rpx 0 16rpx;
}
.result-prefix { font-size: 26rpx; color: #999; display: block; margin-bottom: 8rpx; }
.result-big { font-size: 72rpx; font-weight: 700; color: #4F6EF6; display: block; }
.result-big.past { color: #f5576c; }
.result-unit { font-size: 30rpx; color: #999; }
.result-detail { font-size: 26rpx; color: #999; display: block; margin-top: 8rpx; }
