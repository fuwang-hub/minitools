.hero { padding: 40rpx 32rpx; text-align: center; }
.hero-emoji { font-size: 56rpx; display: block; margin-bottom: 8rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }

.result-area { text-align: center; padding: 48rpx 0 32rpx; }
.result-number {
  font-size: 96rpx; font-weight: 700; color: #667eea;
  display: inline-block; min-width: 200rpx;
}

.setting-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.setting-label { font-size: 28rpx; color: #666; }
.setting-input {
  width: 200rpx; text-align: right; font-size: 32rpx; font-weight: 600; color: #333;
}

.action-area { padding: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; display: block; }

.result-list { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.result-tag {
  background: #f0f2ff; color: #667eea; padding: 12rpx 24rpx;
  border-radius: 24rpx; font-size: 28rpx; font-weight: 600;
}

.clear-btn { font-size: 24rpx; color: #999; }
.history-item { padding: 12rpx 0; border-bottom: 1rpx solid #f8f8f8; }
.history-text { font-size: 26rpx; color: #666; }
