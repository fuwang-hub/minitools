/* pages/tools/calendar/index.wxss */

/* 月份导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
}

.nav-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.nav-btn:active { background: #F0F4FF; }

.nav-arrow {
  font-size: 24rpx;
  color: #4F6EF6;
}

.month-center {
  text-align: center;
}

.month-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
}

.lunar-year {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 2rpx;
}

/* 星期表头 */
.week-header {
  display: flex;
  padding: 0 16rpx;
  margin-bottom: 8rpx;
}

.week-name {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  padding: 12rpx 0;
}

.week-name.weekend {
  color: #EF4444;
}

/* 日历网格 */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}

.day-cell {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
  min-height: 90rpx;
  justify-content: center;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.day-cell.empty {
  visibility: hidden;
}

.day-cell:active {
  background: #F0F4FF;
}

.day-cell.today {
  background: #4F6EF6;
  border-radius: 16rpx;
}

.day-cell.today .day-num {
  color: #fff;
}

.day-cell.today .day-lunar {
  color: rgba(255, 255, 255, 0.8);
}

.day-cell.selected {
  background: #EEF2FF;
  border-radius: 16rpx;
}

.day-cell.today.selected {
  background: #4F6EF6;
}

.day-num {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1.2;
}

.day-cell.weekend .day-num {
  color: #EF4444;
}

.day-cell.today.weekend .day-num {
  color: #fff;
}

.day-lunar {
  font-size: 18rpx;
  color: #999;
  line-height: 1.2;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.day-lunar.festival {
  color: #4F6EF6;
  font-weight: 500;
}

.day-cell.today .day-lunar.festival {
  color: rgba(255, 255, 255, 0.9);
}

/* 选中日期详情 */
.detail-card {
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-date {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-day {
  font-size: 56rpx;
  font-weight: 700;
  color: #4F6EF6;
  line-height: 1;
}

.detail-meta {
  display: flex;
  flex-direction: column;
}

.detail-solar {
  font-size: 24rpx;
  color: #666;
}

.detail-lunar {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-top: 4rpx;
}

.detail-ganchi {
  text-align: right;
}

.ganchi-text {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 600;
  display: block;
}

.shengxiao-text {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

/* 节日列表 */
.festival-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F2F5;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.festival-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
}

.festival-item.solar { background: #FEF2F2; }
.festival-item.lunar { background: #FEF7ED; }
.festival-item.term { background: #ECFDF5; }

.fest-icon { font-size: 28rpx; }

.fest-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  flex: 1;
}

.fest-type {
  font-size: 22rpx;
  color: #999;
}

/* 回到今天 */
.today-btn {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #4F6EF6;
  font-weight: 500;
}

.today-btn:active { opacity: 0.7; }
