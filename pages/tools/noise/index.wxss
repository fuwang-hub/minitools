/* pages/tools/noise/index.wxss */
.container { min-height: 100vh; padding-bottom: 40rpx; transition: background 0.3s; }
.meter-area { text-align: center; padding: 40rpx 0 20rpx; }
.meter { width: 400rpx; height: 240rpx; margin: 0 auto; position: relative; }
.meter-bg { width: 400rpx; height: 200rpx; border-radius: 200rpx 200rpx 0 0; background: linear-gradient(90deg, #10b981 0%, #fbbf24 50%, #ef4444 100%); position: relative; overflow: hidden; }
.meter-scale { position: absolute; width: 100%; height: 100%; }
.scale-num { position: absolute; font-size: 20rpx; color: #fff; font-weight: 600; }
.s-0 { bottom: 10rpx; left: 20rpx; }
.s-30 { top: 50rpx; left: 50rpx; }
.s-60 { top: 10rpx; left: 50%; transform: translateX(-50%); }
.s-90 { top: 50rpx; right: 50rpx; }
.s-120 { bottom: 10rpx; right: 20rpx; }
.meter-needle { position: absolute; bottom: 0; left: 50%; width: 6rpx; height: 170rpx; background: #1f2937; transform-origin: bottom center; border-radius: 3rpx; transition: transform 0.2s ease-out; margin-left: -3rpx; }
.meter-center { position: absolute; bottom: -12rpx; left: 50%; width: 24rpx; height: 24rpx; background: #1f2937; border-radius: 50%; margin-left: -12rpx; }
.db-display { text-align: center; margin-top: 16rpx; }
.db-num { font-size: 72rpx; font-weight: 700; line-height: 1; }
.db-unit { font-size: 28rpx; color: #6b7280; margin-left: 4rpx; }
.level-emoji { font-size: 48rpx; display: block; margin-top: 16rpx; }
.level-label { font-size: 32rpx; font-weight: 600; display: block; margin-top: 8rpx; }
.level-desc { font-size: 24rpx; color: #6b7280; display: block; margin-top: 4rpx; }
/* 统计 */
.stats-row { display: flex; margin: 20rpx 28rpx; background: #fff; border-radius: 20rpx; padding: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.stat-item { flex: 1; text-align: center; }
.st-val { font-size: 32rpx; font-weight: 700; display: block; }
.st-label { font-size: 20rpx; color: #9ca3af; display: block; margin-top: 4rpx; }
/* 波形 */
.wave-card { margin: 16rpx 28rpx; background: #fff; border-radius: 20rpx; padding: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.wave-title { font-size: 26rpx; color: #374151; font-weight: 600; display: block; margin-bottom: 12rpx; }
.wave-bars { display: flex; align-items: flex-end; height: 120rpx; gap: 2rpx; }
.wave-bar { flex: 1; min-width: 4rpx; border-radius: 2rpx; transition: height 0.1s; }
/* 控制 */
.ctrl-area { display: flex; justify-content: center; padding: 30rpx 0; }
.main-btn { width: 240rpx; height: 240rpx; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15); }
.main-btn.start { background: linear-gradient(135deg, #10b981, #059669); }
.main-btn.stop { background: linear-gradient(135deg, #ef4444, #dc2626); }
.main-btn:active { opacity: 0.8; transform: scale(0.95); }
.btn-icon { font-size: 48rpx; display: block; }
.btn-text { font-size: 24rpx; color: #fff; margin-top: 8rpx; }
/* 参考 */
.ref-card { margin: 16rpx 28rpx; background: #fff; border-radius: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.ref-title { font-size: 28rpx; color: #1f2937; font-weight: 600; display: block; margin-bottom: 16rpx; }
.ref-row { display: flex; align-items: center; gap: 12rpx; padding: 10rpx 0; }
.ref-dot { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; }
.ref-range { font-size: 24rpx; color: #374151; font-weight: 500; width: 130rpx; }
.ref-desc { font-size: 22rpx; color: #6b7280; flex: 1; }
