<!--pages/tools/mortgage/index.wxml-->
<view class="page-container">
  <!-- Hero -->
<!-- 贷款类型切换 -->
  <view class="tab-bar">
    <view class="tab-item {{loanType === item.key ? 'active' : ''}}"
          wx:for="{{loanTypes}}" wx:key="key"
          bindtap="switchLoanType" data-type="{{item.key}}">
      {{item.name}}
    </view>
  </view>

  <!-- 输入表单 -->
  <view class="form-card">
    <!-- 房屋总价 -->
    <view class="field-row">
      <text class="field-label">房屋总价</text>
      <view class="field-input-area">
        <input class="field-input" type="digit" placeholder="请输入"
               value="{{totalPrice}}" bindinput="onTotalPriceInput" />
        <text class="field-unit">万元</text>
      </view>
    </view>

    <!-- 首付比例 -->
    <view class="field-row">
      <text class="field-label">首付比例</text>
      <picker range="{{downPaymentRates}}" value="{{1}}" bindchange="onDownPaymentChange">
        <view class="field-picker">{{downPaymentRate}}% <text class="picker-arrow">▼</text></view>
      </picker>
    </view>

    <!-- 贷款金额（非组合贷） -->
    <view class="field-row" wx:if="{{loanType !== 'combo'}}">
      <text class="field-label">贷款金额</text>
      <view class="field-input-area">
        <input class="field-input" type="digit" placeholder="自动计算"
               value="{{loanAmount}}" bindinput="onLoanAmountInput" />
        <text class="field-unit">万元</text>
      </view>
    </view>

    <!-- 组合贷两个金额 -->
    <block wx:if="{{loanType === 'combo'}}">
      <view class="field-row">
        <text class="field-label">商贷金额</text>
        <view class="field-input-area">
          <input class="field-input" type="digit" placeholder="请输入"
                 value="{{comboCommercial}}" bindinput="onComboCommercialInput" />
          <text class="field-unit">万元</text>
        </view>
      </view>
      <view class="field-row">
        <text class="field-label">公积金金额</text>
        <view class="field-input-area">
          <input class="field-input" type="digit" placeholder="请输入"
                 value="{{comboFund}}" bindinput="onComboFundInput" />
          <text class="field-unit">万元</text>
        </view>
      </view>
    </block>

    <!-- 贷款年限 -->
    <view class="field-row">
      <text class="field-label">贷款年限</text>
      <picker range="{{yearOptions}}" value="{{5}}" bindchange="onYearsChange">
        <view class="field-picker">{{loanYears}}年 <text class="picker-arrow">▼</text></view>
      </picker>
    </view>

    <!-- 商贷利率 -->
    <view class="field-row" wx:if="{{loanType !== 'fund'}}">
      <text class="field-label">商贷利率</text>
      <view class="field-input-area">
        <input class="field-input" type="digit"
               value="{{commercialRate}}" bindinput="onCommercialRateInput" />
        <text class="field-unit">%</text>
      </view>
    </view>

    <!-- 公积金利率 -->
    <view class="field-row" wx:if="{{loanType !== 'commercial'}}">
      <text class="field-label">公积金利率</text>
      <view class="field-input-area">
        <input class="field-input" type="digit"
               value="{{fundRate}}" bindinput="onFundRateInput" />
        <text class="field-unit">%</text>
      </view>
    </view>

    <!-- 还款方式 -->
    <view class="field-row repay-field">
      <text class="field-label">还款方式</text>
      <view class="repay-toggle">
        <view class="repay-opt {{repayType === 'equal_payment' ? 'active' : ''}}"
              bindtap="switchRepayType" data-type="equal_payment">等额本息</view>
        <view class="repay-opt {{repayType === 'equal_principal' ? 'active' : ''}}"
              bindtap="switchRepayType" data-type="equal_principal">等额本金</view>
      </view>
    </view>
  </view>

  <!-- 计算按钮 -->
  <view class="btn-primary calc-btn" bindtap="calculate">开始计算</view>

  <!-- 计算结果 -->
  <view class="result-section" wx:if="{{result}}">
    <!-- 月供高亮卡片 -->
    <view class="result-card-highlight">
      <view class="res-tag-wrap">
        <text class="res-tag">{{result.repayType}}</text>
      </view>
      <text class="res-label">{{repayType === 'equal_principal' ? '首月月供' : '每月月供'}}</text>
      <text class="res-amount">¥{{result.monthlyPayment}}</text>
      <text class="res-sub" wx:if="{{result.monthlyLast}}">末月月供：¥{{result.monthlyLast}}</text>
    </view>

    <!-- 贷款明细卡片 -->
    <view class="result-card">
      <view class="stat-grid">
        <view class="stat-item">
          <text class="stat-value">{{result.totalLoanWan}}万</text>
          <text class="stat-label">贷款总额</text>
        </view>
        <view class="stat-item">
          <text class="stat-value highlight">{{result.totalInterestWan}}万</text>
          <text class="stat-label">利息总额</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{result.totalPaymentWan}}万</text>
          <text class="stat-label">还款总额</text>
        </view>
      </view>

      <!-- 组合贷明细 -->
      <view class="combo-section" wx:if="{{result.isCombo}}">
        <view class="combo-item">
          <text class="combo-name">商贷</text>
          <text class="combo-val">月供 ¥{{result.part1.monthly}}</text>
          <text class="combo-ext">利息 {{result.part1.interest}}万</text>
        </view>
        <view class="combo-item">
          <text class="combo-name">公积金</text>
          <text class="combo-val">月供 ¥{{result.part2.monthly}}</text>
          <text class="combo-ext">利息 {{result.part2.interest}}万</text>
        </view>
      </view>

      <!-- 还款明细展开 -->
      <view class="detail-btn" bindtap="toggleDetail">
        <text>{{showDetail ? '收起明细 ▲' : '查看还款明细 ▼'}}</text>
      </view>

      <view class="detail-table" wx:if="{{showDetail}}">
        <view class="tb-head">
          <text class="tb-th">月份</text>
          <text class="tb-th">月供</text>
          <text class="tb-th">本金</text>
          <text class="tb-th">利息</text>
        </view>
        <view class="tb-row" wx:for="{{detailMonths}}" wx:key="month">
          <text class="tb-td">{{item.month > 0 ? '第' + item.month + '月' : '...'}}</text>
          <text class="tb-td">{{item.payment}}</text>
          <text class="tb-td">{{item.principal}}</text>
          <text class="tb-td">{{item.interest}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 广告 -->
  <ad-banner />

  <!-- 提示 -->
  <view class="tips-card">
    <text class="tips-title">💡 小贴士</text>
    <text class="tips-item">• 2024年最新LPR商贷基准利率为3.45%</text>
    <text class="tips-item">• 公积金贷款5年以上利率为2.85%</text>
    <text class="tips-item">• 等额本息月供固定，适合收入稳定人群</text>
    <text class="tips-item">• 等额本金总利息少，前期月供较高</text>
  </view>

  <!-- SEO: 搜索引擎索引文本 -->
  <view class="seo-text" aria-hidden="true">房贷计算器在线计算，支持商业贷款、公积金贷款、组合贷款，等额本息等额本金月供计算，还款明细查看。</view>
</view>
