/* pages/tools/mortgage/index.wxss */
.container { min-height: 100vh; padding-bottom: 40rpx; }
.type-bar { display: flex; margin: 20rpx 28rpx; background: rgba(255,255,255,0.1); border-radius: 16rpx; padding: 6rpx; }
.type-btn { flex: 1; text-align: center; padding: 18rpx 0; font-size: 26rpx; color: rgba(255,255,255,0.7); border-radius: 12rpx; }
.type-btn.active { background: #fff; color: #1e3a5f; font-weight: 600; }
.form-card { margin: 16rpx 28rpx; background: rgba(255,255,255,0.12); border-radius: 24rpx; padding: 8rpx 28rpx; backdrop-filter: blur(10px); }
.form-row { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.form-row:last-child { border-bottom: none; }
.form-label { font-size: 28rpx; color: #fff; flex-shrink: 0; width: 170rpx; }
.form-input-wrap { display: flex; align-items: center; flex: 1; justify-content: flex-end; }
.form-input { text-align: right; color: #fff; font-size: 30rpx; font-weight: 500; width: 200rpx; }
.form-unit { font-size: 24rpx; color: rgba(255,255,255,0.6); margin-left: 8rpx; width: 60rpx; }
.picker-value { font-size: 30rpx; color: #fff; font-weight: 500; }
.repay-row { flex-direction: column; align-items: flex-start; gap: 16rpx; }
.repay-btns { display: flex; gap: 16rpx; width: 100%; }
.repay-btn { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: rgba(255,255,255,0.7); border: 2rpx solid rgba(255,255,255,0.3); border-radius: 12rpx; }
.repay-btn.active { background: rgba(255,255,255,0.2); border-color: #fff; color: #fff; font-weight: 600; }
.calc-btn { margin: 24rpx 28rpx; height: 88rpx; line-height: 88rpx; text-align: center; background: linear-gradient(135deg, #f59e0b, #f97316); color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 44rpx; }
.calc-btn:active { opacity: 0.8; }
.result-card { margin: 16rpx 28rpx; background: rgba(255,255,255,0.95); border-radius: 24rpx; padding: 32rpx; color: #1f2937; }
.result-header { margin-bottom: 16rpx; }
.result-tag { font-size: 24rpx; background: #dbeafe; color: #1e40af; padding: 6rpx 16rpx; border-radius: 8rpx; }
.result-main { text-align: center; padding: 20rpx 0; }
.result-label { font-size: 26rpx; color: #6b7280; display: block; }
.result-amount { font-size: 56rpx; font-weight: 700; color: #dc2626; display: block; margin: 8rpx 0; }
.result-sub { font-size: 26rpx; color: #6b7280; display: block; }
.result-grid { display: flex; border-top: 1rpx solid #f3f4f6; padding-top: 20rpx; margin-top: 16rpx; }
.grid-item { flex: 1; text-align: center; }
.g-value { font-size: 30rpx; font-weight: 600; color: #1f2937; display: block; }
.g-label { font-size: 22rpx; color: #9ca3af; display: block; margin-top: 4rpx; }
.combo-detail { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f3f4f6; }
.combo-row { display: flex; align-items: center; gap: 16rpx; padding: 8rpx 0; }
.c-name { font-size: 26rpx; color: #1e40af; font-weight: 500; width: 80rpx; }
.c-monthly { font-size: 26rpx; color: #374151; flex: 1; }
.c-interest { font-size: 24rpx; color: #6b7280; }
.detail-toggle { text-align: center; padding: 20rpx 0 8rpx; font-size: 26rpx; color: #3b82f6; }
.detail-table { margin-top: 12rpx; }
.table-header { display: flex; background: #f9fafb; border-radius: 8rpx; padding: 12rpx 0; }
.th { flex: 1; text-align: center; font-size: 22rpx; color: #6b7280; font-weight: 600; }
.table-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f9fafb; }
.td { flex: 1; text-align: center; font-size: 22rpx; color: #374151; }
.tips-card { margin: 16rpx 28rpx; background: rgba(255,255,255,0.08); border-radius: 20rpx; padding: 24rpx; }
.tips-title { font-size: 28rpx; color: #fff; font-weight: 600; display: block; margin-bottom: 12rpx; }
.tips-text { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; line-height: 2; }
