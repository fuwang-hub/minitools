/* pages/tools/ledger/index.wxss */
.tab-bar { display: flex; margin: 16rpx 30rpx; background: #F0F2F5; border-radius: 16rpx; padding: 6rpx; }
.tab-item { flex: 1; text-align: center; padding: 18rpx 0; font-size: 28rpx; color: #666; border-radius: 12rpx; }
.tab-item.active { background: #fff; color: #7c3aed; font-weight: 600; }
.type-switch { display: flex; margin: 16rpx 30rpx; gap: 16rpx; }
.ts-btn { flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; color: #666; border: 2rpx solid #EAEEF3; border-radius: 12rpx; }
.ts-btn.active.exp { background: #FFEBEE; border-color: #EF4444; color: #EF4444; }
.ts-btn.active.inc { background: #E8F9EE; border-color: #10B981; color: #10B981; }
.cat-grid { display: flex; flex-wrap: wrap; margin: 12rpx 30rpx; gap: 8rpx; }
.cat-item { width: calc(25% - 8rpx); text-align: center; padding: 16rpx 0; border-radius: 12rpx; background: #F5F7FA; }
.cat-item.active { background: #F0F4FF; }
.cat-emoji { font-size: 32rpx; display: block; }
.cat-name { font-size: 20rpx; color: #1A1A1A; display: block; margin-top: 4rpx; }
.input-card { margin: 16rpx 30rpx; background: #FFFFFF; border-radius: 24rpx; padding: 24rpx; }
.amount-row { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 2rpx solid #e5e7eb; }
.currency { font-size: 40rpx; color: #7c3aed; font-weight: 700; margin-right: 12rpx; }
.amount-input { flex: 1; font-size: 48rpx; font-weight: 700; color: #1f2937; }
.extra-row { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; }
.date-picker { font-size: 26rpx; color: #6b7280; }
.remark-input { flex: 1; font-size: 26rpx; color: #374151; text-align: right; }
.save-btn { margin-top: 16rpx; height: 80rpx; line-height: 80rpx; text-align: center; background: #7c3aed; color: #fff; border-radius: 40rpx; font-size: 30rpx; font-weight: 600; }
.save-btn:active { opacity: 0.8; }
.month-bar { display: flex; align-items: center; justify-content: center; padding: 20rpx; gap: 24rpx; }
.month-arrow { font-size: 24rpx; color: #666; padding: 8rpx 16rpx; }
.month-text { font-size: 30rpx; color: #1A1A1A; font-weight: 600; }
.summary-row { display: flex; margin: 0 30rpx; background: #EAEEF3; border-radius: 16rpx; padding: 20rpx; }
.sum-item { flex: 1; text-align: center; }
.s-label { font-size: 22rpx; color: #999; display: block; }
.s-val { font-size: 30rpx; font-weight: 600; color: #1A1A1A; display: block; margin-top: 4rpx; }
.s-val.exp { color: #EF4444; }
.s-val.inc { color: #10B981; }
.record-group { margin: 12rpx 30rpx; }
.group-header { display: flex; justify-content: space-between; padding: 12rpx 0; }
.group-date { font-size: 24rpx; color: #666; }
.group-sum { font-size: 22rpx; color: #999; }
.record-item { display: flex; align-items: center; background: #F0F2F5; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 8rpx; gap: 16rpx; }
.r-emoji { font-size: 32rpx; }
.r-info { flex: 1; }
.r-cat { font-size: 26rpx; color: #1A1A1A; display: block; }
.r-remark { font-size: 22rpx; color: #999; display: block; }
.r-amount { font-size: 30rpx; font-weight: 600; }
.r-amount.exp { color: #EF4444; }
.r-amount.inc { color: #10B981; }
.empty-tip { text-align: center; padding: 60rpx; }
.empty-icon { font-size: 48rpx; display: block; }
.empty-text { font-size: 26rpx; color: #999; display: block; margin-top: 12rpx; }
.stat-total { text-align: center; padding: 24rpx; }
.st-label { font-size: 26rpx; color: #666; display: block; }
.st-value { font-size: 52rpx; font-weight: 700; color: #1A1A1A; display: block; }
.stat-list { margin: 0 30rpx; }
.stat-item { display: flex; align-items: center; background: #F0F2F5; border-radius: 16rpx; padding: 20rpx; margin-bottom: 12rpx; gap: 16rpx; }
.si-emoji { font-size: 32rpx; }
.si-info { flex: 1; }
.si-top { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.si-name { font-size: 26rpx; color: #1A1A1A; }
.si-amount { font-size: 26rpx; color: #1A1A1A; font-weight: 500; }
.si-bar-bg { height: 8rpx; background: #F0F2F5; border-radius: 4rpx; }
.si-bar-fill { height: 100%; background: #c4b5fd; border-radius: 4rpx; }
.si-percent { font-size: 24rpx; color: #999; width: 80rpx; text-align: right; }
