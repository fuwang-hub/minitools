/* pages/tools/exchange/index.wxss */
.rate-info { text-align: center; padding: 20rpx; }
.rate-text { font-size: 30rpx; color: #1A1A1A; font-weight: 600; display: block; }
.update-text { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.exchange-card { margin: 16rpx 30rpx; background: #FFFFFF; border-radius: 24rpx; padding: 8rpx 30rpx; position: relative; }
.currency-row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.currency-row:last-child { border-bottom: none; }
.cur-selector { display: flex; align-items: center; gap: 8rpx; width: 200rpx; }
.cur-flag { font-size: 32rpx; }
.cur-code { font-size: 28rpx; font-weight: 600; color: #1f2937; }
.cur-arrow { font-size: 18rpx; color: #9ca3af; }
.cur-input { flex: 1; text-align: right; font-size: 36rpx; font-weight: 600; color: #1f2937; }
.swap-btn { position: absolute; right: 28rpx; top: 50%; transform: translateY(-50%); width: 64rpx; height: 64rpx; background: #3b82f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 1; box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.4); }
.swap-icon { font-size: 28rpx; }
.loading-row { text-align: center; padding: 16rpx; }
.loading-text { font-size: 24rpx; color: #666; }
.common-card { margin: 16rpx 30rpx; background: #FFFFFF; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); border-radius: 24rpx; padding: 24rpx; }
.card-title { font-size: 26rpx; color: #1A1A1A; font-weight: 600; display: block; margin-bottom: 16rpx; }
.rate-row { display: flex; justify-content: space-between; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid #EAEEF3; }
.rate-row:last-child { border-bottom: none; }
.rate-left { display: flex; align-items: center; gap: 12rpx; }
.r-flag { font-size: 24rpx; }
.r-name { font-size: 26rpx; color: #1A1A1A; }
.r-code { font-size: 22rpx; color: #999; }
.r-rate { font-size: 28rpx; color: #1A1A1A; font-weight: 500; }
.tip-card { margin: 16rpx 30rpx; padding: 20rpx; }
.tip-text { font-size: 22rpx; color: #999; display: block; line-height: 1.8; }
