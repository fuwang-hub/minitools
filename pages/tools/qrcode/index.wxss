.hero { padding: 40rpx 32rpx; text-align: center; }
.hero-emoji { font-size: 56rpx; display: block; margin-bottom: 8rpx; }
.hero-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }

.label { font-size: 28rpx; color: #666; display: block; margin-bottom: 12rpx; }
.text-area {
  width: 100%; height: 200rpx; background: #f8f9fa; border-radius: 16rpx;
  padding: 20rpx; font-size: 28rpx; color: #333; line-height: 1.6;
}
.char-count { font-size: 22rpx; color: #bbb; display: block; text-align: right; margin-top: 8rpx; }

.action-area { padding: 24rpx; }

.qr-card { display: flex; flex-direction: column; align-items: center; }
.qr-canvas { margin: 24rpx 0; }
.qr-actions { display: flex; gap: 24rpx; }
.qr-btn {
  padding: 16rpx 32rpx; background: #f0f2ff; border-radius: 24rpx;
  font-size: 26rpx; color: #667eea;
}
.qr-btn:active { opacity: 0.7; }
