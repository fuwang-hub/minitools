<view class="page-container">
  <view class="hero">
    <text class="hero-emoji">📱</text>
    <text class="hero-title">二维码生成</text>
  </view>

  <view class="card">
    <text class="label">输入内容</text>
    <textarea class="text-area" placeholder="输入文本或链接，生成二维码"
              value="{{text}}" bindinput="onInput" maxlength="500" />
    <text class="char-count">{{text.length}}/500</text>
  </view>

  <view class="action-area">
    <view class="btn-primary" style="text-align:center;" bindtap="onGenerate">
      <text>生成二维码</text>
    </view>
  </view>

  <!-- 二维码展示 -->
  <view class="card qr-card" wx:if="{{showQR}}">
    <canvas canvas-id="qrCanvas" class="qr-canvas"
            style="width: 400rpx; height: 400rpx;" />
    <view class="qr-actions">
      <view class="qr-btn" bindtap="onSave">
        <text>💾 保存到相册</text>
      </view>
    </view>
  </view>

  <ad-banner type="banner" />
</view>
