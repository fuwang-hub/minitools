/* pages/login/index.wxss */
.login-page { min-height: 100vh; background: #fff; display: flex; flex-direction: column; align-items: center; padding: 0 60rpx; box-sizing: border-box; }

/* Logo */
.logo-section { margin-top: 120rpx; text-align: center; }
.logo-emoji { font-size: 100rpx; display: block; }
.logo-title { font-size: 40rpx; font-weight: 700; color: #1a1a1a; display: block; margin-top: 16rpx; }
.logo-desc { font-size: 26rpx; color: #999; display: block; margin-top: 8rpx; }

/* 表单 */
.form-section { width: 100%; margin-top: 80rpx; }
.form-item { display: flex; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.form-label { font-size: 30rpx; color: #1a1a1a; width: 100rpx; flex-shrink: 0; }

/* 头像 */
.avatar-btn { display: flex !important; align-items: center; background: transparent !important; border: none !important; padding: 0 !important; margin: 0 !important; line-height: normal !important; }
.avatar-btn::after { display: none; }
.avatar-preview { width: 80rpx; height: 80rpx; border-radius: 50%; background: #f5f5f5; }
.avatar-tip { font-size: 24rpx; color: #4F6EF6; margin-left: 16rpx; }

/* 昵称 */
.nickname-input { flex: 1; font-size: 30rpx; color: #1a1a1a; height: 80rpx; }

/* 按钮 */
.btn-section { width: 100%; margin-top: 60rpx; }
.confirm-btn { width: 100%; height: 88rpx; line-height: 88rpx; text-align: center; background: linear-gradient(135deg, #4F6EF6, #6C8AFF); color: #fff; border-radius: 44rpx; font-size: 32rpx; font-weight: 600; }
.confirm-btn:active { opacity: 0.8; }
.skip-btn { text-align: center; margin-top: 24rpx; padding: 20rpx; color: #999; font-size: 28rpx; }

/* 协议 */
.agreement { position: fixed; bottom: 60rpx; left: 0; right: 0; text-align: center; padding-bottom: env(safe-area-inset-bottom); }
.agreement-text { font-size: 22rpx; color: #ccc; }
